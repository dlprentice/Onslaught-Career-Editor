root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sln,bat,cmd,ps1,psm1,psd1}]
end_of_line = crlf

[game/**/*.{msl,txt,stf,par,sfx,htm,xml,h}]
end_of_line = crlf
trim_trailing_whitespace = false

[game/**/*.log]
end_of_line = crlf
trim_trailing_whitespace = false

[game/**/*.LOG]
end_of_line = crlf
trim_trailing_whitespace = false

[*.md]
trim_trailing_whitespace = false
