{
  "name": "onslaught-toolkit-public-source",
  "private": true,
  "version": "1.0.9",
  "description": "Curated WinUI toolkit and GPL rebuild source validation scripts for Onslaught Toolkit.",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "test": "npm run check:quick",
    "check:quick": "npm run test:doc-commands && npm run build:winui && npm run test:appcore && npm run test:winui && npm run test:rebuild",
    "dev": "dotnet run --project .\\OnslaughtCareerEditor.WinUI\\OnslaughtCareerEditor.WinUI.csproj",
    "build": "dotnet build .\\OnslaughtCareerEditor.WinUI\\OnslaughtCareerEditor.WinUI.csproj --nologo",
    "build:winui": "dotnet build .\\OnslaughtCareerEditor.WinUI\\OnslaughtCareerEditor.WinUI.csproj --nologo",
    "build:cli": "dotnet build .\\OnslaughtCareerEditor.Cli\\OnslaughtCareerEditor.Cli.csproj --nologo",
    "build:host": "dotnet build .\\OnslaughtCareerEditor.AppCore.Host\\OnslaughtCareerEditor.AppCore.Host.csproj --nologo",
    "build:rebuild-core": "dotnet build .\\rebuild\\OnslaughtRebuild.Core\\OnslaughtRebuild.Core.csproj --nologo",
    "test:rebuild-core": "dotnet test .\\rebuild\\OnslaughtRebuild.Core.Tests\\OnslaughtRebuild.Core.Tests.csproj --nologo",
    "build:rebuild-client": "dotnet build .\\rebuild\\OnslaughtRebuild.Client\\OnslaughtRebuild.Client.csproj --nologo",
    "test:rebuild-client": "dotnet test .\\rebuild\\OnslaughtRebuild.Client.Tests\\OnslaughtRebuild.Client.Tests.csproj --nologo",
    "test:rebuild-godot-toolchain": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\GodotToolchain.Tests.ps1",
    "test:rebuild-godot-smoke-validation": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\FirstFlightSmokeValidation.Tests.ps1 && pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\FirstFlightSmokeRunner.Tests.ps1",
    "test:rebuild": "npm run test:rebuild-core && npm run test:rebuild-client && npm run test:rebuild-godot-toolchain && npm run test:rebuild-godot-smoke-validation",
    "run:rebuild-headless": "dotnet run --project .\\rebuild\\OnslaughtRebuild.Headless\\OnslaughtRebuild.Headless.csproj --",
    "setup:rebuild-godot": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\Setup-Godot.ps1",
    "build:rebuild-godot": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\Build-FirstFlight.ps1",
    "run:rebuild-godot": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\Run-FirstFlight.ps1",
    "test:rebuild-godot-smoke": "pwsh -NoLogo -NoProfile -File .\\rebuild\\tools\\Smoke-FirstFlight.ps1",
    "build:release": "dotnet build .\\OnslaughtCareerEditor.Release.slnx --nologo",
    "test:appcore": "dotnet test .\\OnslaughtCareerEditor.AppCore.Tests\\OnslaughtCareerEditor.AppCore.Tests.csproj --nologo",
    "test:winui": "dotnet test .\\OnslaughtCareerEditor.UiTests\\OnslaughtCareerEditor.UiTests.csproj --nologo --filter \"FullyQualifiedName!~LegacyWpf\"",
    "test:winui-primary-lane": "py -3 -B tools\\winui_primary_lane_validation.py",
    "test:winui-safe-copy-preflight": "dotnet test .\\OnslaughtCareerEditor.AppCore.Tests\\OnslaughtCareerEditor.AppCore.Tests.csproj --nologo --filter \"FullyQualifiedName~GameProfilePreflightServiceTests\" && dotnet test .\\OnslaughtCareerEditor.UiTests\\OnslaughtCareerEditor.UiTests.csproj --nologo --filter \"FullyQualifiedName~WinUiProductLaneTests.PatchBench|FullyQualifiedName~WinUiAccessibilityAuditTests.PrimaryShellAndLongWorkflowControls\" && npm run test:runtime-profile-helper-safety",
    "test:runtime-profile-helper-safety": "py -3 -B tools\\prepare_game_profile_test.py",
    "test:winui-patch-catalog-accounting": "py -3 -B tools\\winui_patch_catalog_accounting_check.py --check",
    "test:winui-patch-engine-safety": "dotnet test .\\OnslaughtCareerEditor.UiTests\\OnslaughtCareerEditor.UiTests.csproj --nologo --filter \"FullyQualifiedName~BinaryPatchRegressionTests\" && npm run test:winui-patch-catalog-accounting",
    "test:winui-msix-candidate-probe": "py -3 -B tools\\winui_msix_candidate_probe.py --check",
    "test:winui-installer-preflight": "py -3 -B tools\\winui_installer_preflight.py --check",
    "test:doc-commands": "py -3 -B tools\\public_package_doc_command_check.py --self-test && py -3 -B tools\\public_package_doc_command_check.py",
    "test:md-links": "py -3 -B tools\\md_link_check.py --scope all --out-dir subagents\\md-link-check",
    "test:hard-payload-safety": "py -3 -B tools\\hard_payload_safety_check.py --self-test && py -3 -B tools\\hard_payload_safety_check.py --payload-root . --require-private-text-guard",
    "test:public-allowlist": "py -3 -B tools\\public_allowlist_safety_check.py --self-test && py -3 -B tools\\public_allowlist_safety_check.py --payload-root . --require-private-text-guard",
    "test:public-candidate-inventory": "py -3 -B tools\\public_candidate_inventory_check.py --self-test && py -3 -B tools\\public_candidate_inventory_check.py --candidate-root .",
    "test:repo-hygiene": "py -3 -B tools\\repo_text_hygiene_check_test.py && py -3 -B tools\\repo_text_hygiene_check.py && py -3 -B tools\\repo_line_endings_check_test.py && py -3 -B tools\\repo_line_endings_check.py",
    "test:winui-notices": "dotnet restore .\\OnslaughtCareerEditor.WinUI.slnx --nologo && dotnet restore .\\OnslaughtCareerEditor.Release.slnx --nologo && py -3 -B tools\\generate_winui_third_party_notices.py --check"
  }
}
