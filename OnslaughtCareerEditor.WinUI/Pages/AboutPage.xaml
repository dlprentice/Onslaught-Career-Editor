<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AutomationProperties.AutomationId="AboutPageRoot"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <ScrollViewer AutomationProperties.AutomationId="AboutPageScrollViewer"
                  AutomationProperties.Name="About page content">
        <StackPanel Padding="20,18,20,24">
            <TextBlock Text="About Onslaught Toolkit"
                       AutomationProperties.AutomationId="AboutPageTitle"
                       AutomationProperties.HeadingLevel="Level1"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Margin="0,6,0,14"
                       AutomationProperties.AutomationId="AboutProductSummary"
                       Text="Primary Windows app for Battle Engine Aquila save editing, global options, media/lore browsing, and playable copied-game patching."
                       Style="{StaticResource SectionBodyTextStyle}" />

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Core capabilities"
                               AutomationProperties.AutomationId="AboutCoreCapabilitiesTitle"
                               AutomationProperties.HeadingLevel="Level2"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="- Save Lab: inspect .bes career saves, patch copied outputs, and preserve unknown regions."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="- Game Options: patch defaultoptions.bea for startup settings and keybind state."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="- Windowed &amp; Mods: create a playable copied game folder, patch only that copy, launch that copy, and keep advanced BEA.exe-only patching separate."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="- Media + Asset Library + Lore: installed audio/video playback, local generated asset catalog browsing, and curated preservation notes."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Project notes"
                               AutomationProperties.AutomationId="AboutProjectNotesTitle"
                               AutomationProperties.HeadingLevel="Level2"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="This app does not include the Battle Engine Aquila game itself. When a workflow needs game data, it reads your configured game install as read-only input."
                               AutomationProperties.AutomationId="AboutGameInstallBoundaryNote"
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Onslaught Toolkit is an unofficial community project. It is not affiliated with or endorsed by the game's publishers or rights holders, and its licenses grant no rights in the retail game or its assets."
                               AutomationProperties.AutomationId="AboutAffiliationBoundaryNote"
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="This app is for retail Battle Engine Aquila saves, options, media, and copied-game workflows. It reads existing files and writes copied outputs; patching a copied game does not modify your installed game."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="This WinUI app is the primary user-facing Windows product lane. Maintainer infrastructure and historical app references remain separate from this user app."
                               AutomationProperties.AutomationId="AboutProductLaneNote"
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Contributor setup and technical notes are documented with the source project, not required for normal app use."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Retail behavior notes"
                               AutomationProperties.AutomationId="AboutRetailBehaviorTitle"
                               AutomationProperties.HeadingLevel="Level2"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="The retail executable and retail-generated save/options files remain authoritative. The app is designed to patch existing files carefully instead of inventing new ones."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="defaultoptions.bea is the boot-time source for keybinds and most global settings, while .bes remains the career-progress file the Save Editor targets."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Executable patch flows stay catalog-driven, verified, and backup-guarded. Normal launchable work uses a playable copied game folder; advanced BEA.exe-only patching remains separate."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Version"
                               AutomationProperties.AutomationId="AboutVersionTitle"
                               AutomationProperties.HeadingLevel="Level2"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionTextBlock"
                               AutomationProperties.AutomationId="AboutVersionText"
                               Style="{StaticResource SectionBodyTextStyle}"
                               Text="Version: -" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
