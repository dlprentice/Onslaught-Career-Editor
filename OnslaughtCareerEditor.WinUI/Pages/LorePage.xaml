<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.LorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Padding="20,18,20,20"
          RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Spacing="6">
            <TextBlock Text="Lore"
                       AutomationProperties.AutomationId="LorePageTitle"
                       AutomationProperties.HeadingLevel="Level1"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="Read included Lore documents offline with searchable navigation and document history. Source and External links open in your browser."
                       Style="{StaticResource SectionBodyTextStyle}" />
            <TextBlock x:Name="LoreSourceBoundaryStatusTextBlock"
                       AutomationProperties.AutomationId="LoreSourceBoundaryStatus"
                       Text="Offline library: included document links stay here; Source and External links open in your browser."
                       Style="{StaticResource SectionBodyTextStyle}" />
            <StackPanel Visibility="Collapsed">
                <TextBlock x:Name="LibrarySummaryTextBlock"
                           Text="Loading lore library..." />
                <TextBlock x:Name="LibraryCountTextBlock"
                           Text="Preparing reader..." />
            </StackPanel>
        </StackPanel>

        <controls:SplitView x:Name="LoreSplitView"
                            Grid.Row="1"
                            Background="Transparent"
                            DisplayMode="Inline"
                            IsPaneOpen="True"
                            OpenPaneLength="336"
                            PaneBackground="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                            CompactPaneLength="0">
            <controls:SplitView.Pane>
                <Grid Margin="0,0,16,0"
                      Background="Transparent">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0"
                            Padding="16">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Spacing="6">
                                <TextBlock Text="Library"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Search included titles and document content, then browse the library."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SearchTextBox"
                                             AutomationProperties.AutomationId="LoreSearchBox"
                                             AutomationProperties.Name="Search lore documents"
                                             PlaceholderText="Search documents"
                                             TextChanged="SearchTextBox_TextChanged" />
                                    <Button Grid.Column="1"
                                            AutomationProperties.AutomationId="LoreRefreshButton"
                                            Content="Refresh"
                                            Click="RefreshButton_Click" />
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="PaneStateTextBlock"
                                       AutomationProperties.AutomationId="LoreLibraryStatus"
                                       Grid.Row="1"
                                       Style="{StaticResource SectionBodyTextStyle}"
                                       Text="Library unavailable." />

                            <TreeView x:Name="DocumentTree"
                                      AutomationProperties.AutomationId="LoreDocumentTree"
                                      AutomationProperties.Name="Lore document library"
                                      Grid.Row="2"
                                      Background="Transparent"
                                      SelectionMode="Single"
                                      ItemInvoked="DocumentTree_ItemInvoked"
                                      SelectionChanged="DocumentTree_SelectionChanged" />
                        </Grid>
                    </Border>
                </Grid>
            </controls:SplitView.Pane>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,12"
                        Padding="6,0">
                        <CommandBar Background="Transparent"
                                    DefaultLabelPosition="Right"
                                    HorizontalAlignment="Left"
                                    IsDynamicOverflowEnabled="False">
                        <CommandBar.PrimaryCommands>
                            <AppBarButton x:Name="BackButton"
                                          AutomationProperties.AutomationId="LoreBackButton"
                                          Label="Back"
                                          Click="BackButton_Click">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="Back" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton x:Name="ForwardButton"
                                          AutomationProperties.AutomationId="LoreForwardButton"
                                          Label="Forward"
                                          Click="ForwardButton_Click">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="Forward" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton x:Name="HomeButton"
                                          AutomationProperties.AutomationId="LoreHomeButton"
                                          Label="Home"
                                          Click="HomeButton_Click">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="Home" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton x:Name="ToggleLibraryButton"
                                          AutomationProperties.AutomationId="LoreToggleLibraryButton"
                                          Label="Hide Library"
                                          Click="ToggleLibraryButton_Click">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="List" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarSeparator />
                            <AppBarButton x:Name="OpenExternalButton"
                                          AutomationProperties.AutomationId="LoreOpenExternalButton"
                                          Label="Open in browser"
                                          Click="OpenExternalButton_Click">
                                <AppBarButton.Icon>
                                    <SymbolIcon Symbol="OpenFile" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                        </CommandBar.PrimaryCommands>
                    </CommandBar>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,12"
                        Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="CurrentDocumentTextBlock"
                                   AutomationProperties.AutomationId="LoreCurrentDocumentTitle"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Select a document" />
                        <TextBlock x:Name="CurrentPathTextBlock"
                                   AutomationProperties.AutomationId="LoreCurrentDocumentSummary"
                                   Style="{StaticResource SectionBodyTextStyle}"
                                   Text="Included Lore opens here; Source and External links may open your browser." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        AutomationProperties.AutomationId="LoreReaderPanel"
                        AutomationProperties.Name="Lore document reader"
                        Background="{StaticResource ShellSurfaceBrush}"
                        BorderBrush="{StaticResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <controls:WebView2 x:Name="ContentWebView"
                                           AutomationProperties.AutomationId="LoreContentWebView"
                                           AutomationProperties.Name="Rendered lore document"
                                           NavigationStarting="ContentWebView_NavigationStarting"
                                           NavigationCompleted="ContentWebView_NavigationCompleted" />

                        <Border x:Name="ReaderPlaceholderBorder"
                                AutomationProperties.AutomationId="LoreReaderPlaceholder"
                                Background="{StaticResource ShellSurfaceBrush}"
                                CornerRadius="16">
                            <StackPanel Width="420"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock x:Name="ReaderPlaceholderTitleTextBlock"
                                           AutomationProperties.AutomationId="LoreReaderPlaceholderTitle"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Text="Loading lore library..." />
                                <TextBlock x:Name="ReaderPlaceholderBodyTextBlock"
                                           AutomationProperties.AutomationId="LoreReaderPlaceholderBody"
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           Text="The embedded reader will appear here once the library is ready." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </controls:SplitView>
    </Grid>
</Page>
