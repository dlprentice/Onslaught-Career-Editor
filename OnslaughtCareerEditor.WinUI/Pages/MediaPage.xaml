<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.MediaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="MediaTabButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabButtonBaseStyle}" />
        <Style x:Key="MediaInactiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabInactiveButtonStyle}" />
        <Style x:Key="MediaActiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabActiveButtonStyle}" />
    </Page.Resources>
    <Grid Padding="20,18,20,20"
          RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Spacing="6">
            <TextBlock Text="Media"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="Browse installed music, voice, cutscenes, and briefings from the current game directory. Audio and video now play inline on the page."
                       Style="{StaticResource SectionBodyTextStyle}" />
            <StackPanel Visibility="Collapsed">
                <TextBlock x:Name="MediaSummaryTextBlock"
                           Text="Loading media library..." />
                <TextBlock x:Name="MediaGameDirectoryTextBlock"
                           Text="Game directory not set" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1"
              RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource SubTabStripBorderStyle}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="AudioTabButton"
                            AutomationProperties.AutomationId="MediaAudioTabButton"
                            Content="Audio Library"
                            Click="AudioTabButton_Click"
                            Style="{StaticResource MediaInactiveTabButtonStyle}" />
                    <Button x:Name="VideoTabButton"
                            AutomationProperties.AutomationId="MediaVideoTabButton"
                            Content="Video Player"
                            Click="VideoTabButton_Click"
                            Style="{StaticResource MediaInactiveTabButtonStyle}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid x:Name="AudioTabContentGrid"
                      ColumnSpacing="16"
                      VerticalAlignment="Stretch"
                      Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SectionCardStyle}"
                            Margin="0"
                            VerticalAlignment="Stretch">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Spacing="8">
                                <TextBlock Text="Audio library"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Browse music tracks and voice lines, then double-click a file to start inline playback."
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           MinHeight="56" />
                                <TextBox x:Name="AudioSearchTextBox"
                                         AutomationProperties.AutomationId="MediaAudioSearchBox"
                                         PlaceholderText="Search music and voice"
                                         TextChanged="AudioSearchTextBox_TextChanged" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8">
                                <TreeView x:Name="AudioTreeView"
                                          AutomationProperties.AutomationId="MediaAudioTreeView"
                                          AutomationProperties.Name="Audio library"
                                          MinHeight="0"
                                          VerticalAlignment="Stretch"
                                          SelectionMode="Single"
                                          ItemInvoked="AudioTreeView_ItemInvoked"
                                          SelectionChanged="AudioTreeView_SelectionChanged"
                                          DoubleTapped="AudioTreeView_DoubleTapped" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1"
                          RowSpacing="12"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{ThemeResource MediaVisualizerSurfaceBrush}"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                MinHeight="360"
                                VerticalAlignment="Stretch">
                            <Grid>
                                <Grid Margin="20,20,20,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid x:Name="AudioVisualizerBarsHost"
                                          Grid.Row="0"
                                          VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Right"
                                               Foreground="{ThemeResource ShellMutedTextBrush}"
                                               Text="Visualizer reacts to the current audio output." />
                                </Grid>

                                <Border x:Name="AudioVisualizerPlaceholderBorder"
                                        Background="{ThemeResource MediaOverlaySoftBrush}"
                                        CornerRadius="16">
                                    <StackPanel Width="420"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top"
                                                Margin="0,10,0,0"
                                                Spacing="4">
                                        <TextBlock x:Name="AudioVisualizerStatusTextBlock"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Text="Select a track" />
                                        <TextBlock x:Name="AudioVisualizerHintTextBlock"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="Choose a track from the library, then press Play or double-click it to begin."
                                                   TextAlignment="Center"
                                                   TextWrapping="WrapWholeWords"
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="0"
                                    MinHeight="156">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Now Playing"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="AudioNowPlayingTextBlock"
                                               AutomationProperties.AutomationId="MediaAudioNowPlaying"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="No track selected"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Name="AudioPathTextBlock"
                                               AutomationProperties.AutomationId="MediaAudioSourceSummary"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="Select a track from the library on the left to start playback."
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="0"
                                    MinHeight="156">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Transport"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AudioCurrentTimeTextBlock"
                                                   AutomationProperties.AutomationId="MediaAudioCurrentTime"
                                                   Text="0:00"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="AudioProgressSlider"
                                                AutomationProperties.AutomationId="MediaAudioProgress"
                                                AutomationProperties.Name="Audio progress"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="0"
                                                ValueChanged="AudioProgressSlider_ValueChanged" />
                                        <TextBlock x:Name="AudioTotalTimeTextBlock"
                                                   AutomationProperties.AutomationId="MediaAudioTotalTime"
                                                   Grid.Column="2"
                                                   Text="0:00"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button x:Name="AudioPlayButton"
                                                AutomationProperties.AutomationId="MediaAudioPlayButton"
                                                Content="Play"
                                                Click="AudioPlayButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="AudioPauseButton"
                                                AutomationProperties.AutomationId="MediaAudioPauseButton"
                                                Content="Pause"
                                                Click="AudioPauseButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="AudioStopButton"
                                                AutomationProperties.AutomationId="MediaAudioStopButton"
                                                Content="Stop"
                                                Click="AudioStopButton_Click"
                                                IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Volume"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="AudioVolumeSlider"
                                                AutomationProperties.AutomationId="MediaAudioVolumeSlider"
                                                AutomationProperties.Name="Audio volume"
                                                Width="180"
                                                Minimum="0"
                                                Maximum="100"
                                                ValueChanged="AudioVolumeSlider_ValueChanged" />
                                        <TextBlock x:Name="AudioVolumeTextBlock"
                                                   Text="75%"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="0"
                                    MinHeight="156">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Source folder"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Audio discovery uses the configured install as read-only source material. Browse here to switch immediately, then reload if files changed."
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               MinHeight="56" />
                                    <Border Background="{ThemeResource ShellSurfaceBrush}"
                                            BorderBrush="{ThemeResource ShellBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="AudioGameDirectorySummaryTextBlock"
                                                       AutomationProperties.AutomationId="MediaAudioGameDirectorySummary"
                                                       Text="Checking setup"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock x:Name="AudioGameDirectoryStatusTextBlock"
                                                       Text="Media will scan from the configured read-only install."
                                                       Style="{StaticResource SectionBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <controls:Expander Header="Path details"
                                                       IsExpanded="False">
                                        <TextBlock x:Name="AudioGameDirectoryPathTextBlock"
                                                   TextWrapping="WrapWholeWords"
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </controls:Expander>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Browse Game Directory"
                                                AutomationProperties.AutomationId="MediaAudioBrowseGameDirectoryButton"
                                                Click="BrowseGameDirectoryButton_Click" />
                                        <Button Content="Reload Library"
                                                AutomationProperties.AutomationId="MediaAudioReloadLibraryButton"
                                                Click="ReloadLibraryButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="VideoTabContentGrid"
                      ColumnSpacing="16"
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SectionCardStyle}"
                            Margin="0"
                            VerticalAlignment="Stretch">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Spacing="8">
                                <TextBlock Text="Video library"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Browse videos, cutscenes, and briefings, then double-click a file to start inline playback."
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           MinHeight="56" />
                                <TextBox x:Name="VideoSearchTextBox"
                                         AutomationProperties.AutomationId="MediaVideoSearchBox"
                                         PlaceholderText="Search videos"
                                         TextChanged="VideoSearchTextBox_TextChanged" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8">
                                <TreeView x:Name="VideoTreeView"
                                          AutomationProperties.AutomationId="MediaVideoTreeView"
                                          AutomationProperties.Name="Video library"
                                          MinHeight="0"
                                          VerticalAlignment="Stretch"
                                          SelectionMode="Single"
                                          ItemInvoked="VideoTreeView_ItemInvoked"
                                          SelectionChanged="VideoTreeView_SelectionChanged"
                                          DoubleTapped="VideoTreeView_DoubleTapped" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1"
                          RowSpacing="12"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="Black"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                MinHeight="360"
                                VerticalAlignment="Stretch">
                            <Grid>
                                <Grid Margin="20,20,20,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid x:Name="VideoSurfaceHostGrid"
                                          Grid.Row="0"
                                          VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch">
                                        <Image x:Name="InlineVideoImage"
                                               Stretch="Uniform" />
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Right"
                                               Foreground="{ThemeResource ShellMutedTextBrush}"
                                               Opacity="0"
                                               Text="Inline playback uses the current video selection." />
                                </Grid>

                                <Border x:Name="VideoPlaceholderBorder"
                                        Background="{ThemeResource MediaOverlayStrongBrush}"
                                        CornerRadius="16">
                                    <StackPanel Width="460"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top"
                                                Margin="0,10,0,0"
                                                Spacing="4">
                                        <TextBlock x:Name="VideoPlayerStatusTextBlock"
                                                   AutomationProperties.AutomationId="MediaVideoPlayerStatus"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Text="Select a video" />
                                        <TextBlock x:Name="VideoPlaceholderBodyTextBlock"
                                                   AutomationProperties.AutomationId="MediaVideoPlayerHint"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="Choose a file from the library, then press Play or double-click it to start inline playback."
                                                   TextAlignment="Center"
                                                   TextWrapping="WrapWholeWords"
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="0"
                                    MinHeight="156">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Now Playing"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="VideoSelectedTextBlock"
                                               AutomationProperties.AutomationId="MediaVideoSelected"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="No video selected"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Name="VideoPathTextBlock"
                                               AutomationProperties.AutomationId="MediaVideoSourceSummary"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="Select a video from the library on the left to start playback or reveal the file in Explorer."
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <Button x:Name="RevealVideoButton"
                                            AutomationProperties.AutomationId="MediaRevealVideoButton"
                                            Content="Reveal File"
                                            Click="RevealVideoButton_Click"
                                            IsEnabled="False"
                                            HorizontalAlignment="Left" />
                                    <controls:Expander Header="Source folder"
                                                       IsExpanded="False">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Video discovery uses the configured install as read-only source material. Browse here to switch immediately, then reload if files changed."
                                                       Style="{StaticResource SectionBodyTextStyle}" />
                                            <Border Background="{ThemeResource ShellSurfaceBrush}"
                                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock x:Name="VideoGameDirectorySummaryTextBlock"
                                                               AutomationProperties.AutomationId="MediaVideoGameDirectorySummary"
                                                               Text="Checking setup"
                                                               FontSize="18"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock x:Name="VideoGameDirectoryStatusTextBlock"
                                                               Text="Media will scan from the configured read-only install."
                                                               Style="{StaticResource SectionBodyTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                            <controls:Expander Header="Path details"
                                                               IsExpanded="False">
                                                <TextBlock x:Name="VideoGameDirectoryPathTextBlock"
                                                           TextWrapping="WrapWholeWords"
                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                            </controls:Expander>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Browse Game Directory"
                                                        AutomationProperties.AutomationId="MediaVideoBrowseGameDirectoryButton"
                                                        Click="BrowseGameDirectoryButton_Click" />
                                                <Button Content="Reload Library"
                                                        AutomationProperties.AutomationId="MediaVideoReloadLibraryButton"
                                                        Click="ReloadLibraryButton_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </controls:Expander>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="0"
                                    MinHeight="156">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Transport"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="VideoCurrentTimeTextBlock"
                                                   AutomationProperties.AutomationId="MediaVideoCurrentTime"
                                                   Text="0:00"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="VideoProgressSlider"
                                                AutomationProperties.AutomationId="MediaVideoProgress"
                                                AutomationProperties.Name="Video progress"
                                                Grid.Column="1"
                                                IsEnabled="False"
                                                ValueChanged="VideoProgressSlider_ValueChanged" />
                                        <TextBlock x:Name="VideoTotalTimeTextBlock"
                                                   AutomationProperties.AutomationId="MediaVideoTotalTime"
                                                   Grid.Column="2"
                                                   Text="0:00"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button x:Name="VideoPlayButton"
                                                AutomationProperties.AutomationId="MediaVideoPlayButton"
                                                Content="Play"
                                                Click="VideoPlayButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="VideoPauseButton"
                                                AutomationProperties.AutomationId="MediaVideoPauseButton"
                                                Content="Pause"
                                                Click="VideoPauseButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="VideoStopButton"
                                                AutomationProperties.AutomationId="MediaVideoStopButton"
                                                Content="Stop"
                                                Click="VideoStopButton_Click"
                                                IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Volume"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="VideoVolumeSlider"
                                                AutomationProperties.AutomationId="MediaVideoVolumeSlider"
                                                AutomationProperties.Name="Video volume"
                                                Width="180"
                                                Minimum="0"
                                                Maximum="100"
                                                ValueChanged="VideoVolumeSlider_ValueChanged" />
                                        <TextBlock x:Name="VideoVolumeTextBlock"
                                                   Text="75%"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
