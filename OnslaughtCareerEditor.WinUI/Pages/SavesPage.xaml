                                <TextBox x:Name="ConfigurationCopySourceTextBox"
                                         AutomationProperties.AutomationId="ConfigurationCopySourceTextBox"
                                         Header="Copy source (.bes or .bea)"
                                         TextChanged="ConfigurationCopySourceTextBox_TextChanged" />
