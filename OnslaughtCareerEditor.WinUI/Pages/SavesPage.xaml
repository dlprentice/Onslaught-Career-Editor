<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.SavesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="SavesTabButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabButtonBaseStyle}" />
        <Style x:Key="SavesInactiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabInactiveButtonStyle}" />
        <Style x:Key="SavesActiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabActiveButtonStyle}" />
        <Style x:Key="SavesSectionCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="SavesMetricCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SavesSectionCardStyle}">
            <Setter Property="Background" Value="#FF141B29" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Page.Resources>

    <Grid Padding="20,18,20,18"
          RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,14"
                    Spacing="6">
            <TextBlock Text="Saves"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="Inspect `.bes` career saves and `.bea` global options snapshots, then patch the workflow you need without disturbing retail-backed unknown regions."
                       Style="{StaticResource SectionBodyTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource SubTabStripBorderStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button x:Name="SaveAnalyzerTabButton"
                        Content="Save Analyzer"
                        Click="SaveAnalyzerTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
                <Button x:Name="SaveEditorTabButton"
                        Content="Save Editor"
                        Click="SaveEditorTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
                <Button x:Name="ConfigurationEditorTabButton"
                        Content="Configuration Editor"
                        Click="ConfigurationEditorTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid x:Name="SaveAnalyzerTabContentGrid"
                  Visibility="Visible">
                <Grid ColumnSpacing="0"
                      RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource SavesSectionCardStyle}"
                            CornerRadius="14,0,0,14"
                            BorderThickness="1,1,0,1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Detected files"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Pick from detected save and options files, or refresh after changing the game directory in Settings."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <ComboBox x:Name="DetectedFilesComboBox"
                                      PlaceholderText="No detected files yet"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="DetectedFilesComboBox_SelectionChanged" />
                            <Button x:Name="RefreshDetectedFilesButton"
                                    Content="Refresh detected files"
                                    Click="RefreshDetectedFilesButton_Click" />
                            <TextBlock x:Name="DetectedFilesStatusTextBlock"
                                       Style="{StaticResource SectionBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="0"
                                  Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12">
                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Analyze a file"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FilePathTextBox"
                                             Header="Input file"
                                             TextChanged="FilePathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Browse"
                                                Click="BrowseFileButton_Click" />
                                        <Button x:Name="AnalyzeButton"
                                                Grid.Column="1"
                                                Content="Analyze / Reload"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Click="AnalyzeButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Display options"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <ToggleSwitch x:Name="VerboseToggle"
                                                  Header="Verbose output"
                                                  OffContent="Summary report"
                                                  OnContent="Nodes and bindings"
                                                  Toggled="DisplayOption_Toggled" />
                                    <ToggleSwitch x:Name="DumpMysteryToggle"
                                                  Header="Reserved-byte dump"
                                                  OffContent="Keep compact"
                                                  OnContent="Show reserved-byte details"
                                                  Toggled="DisplayOption_Toggled" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Compare files"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="CompareFilePathTextBox"
                                             Header="Compare against"
                                             TextChanged="CompareFilePathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Browse"
                                                Click="BrowseCompareFileButton_Click" />
                                        <Button x:Name="CompareButton"
                                                Grid.Column="1"
                                                Content="Compare files"
                                                Click="CompareButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="SummaryTitleTextBlock"
                                               Text="Analysis summary"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <controls:TreeView x:Name="SummaryTreeView"
                                                       Grid.Row="1"
                                                       MinHeight="180"
                                                       MaxHeight="280">
                                        <controls:TreeView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="WrapWholeWords"
                                                           MaxWidth="250" />
                                            </DataTemplate>
                                        </controls:TreeView.ItemTemplate>
                                    </controls:TreeView>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="{ThemeResource ShellSurfaceBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            BorderThickness="0,1,0,1"
                            CornerRadius="0" />

                    <controls:InfoBar x:Name="AnalyzerInfoBar"
                                      Grid.Row="0"
                                      Grid.Column="2"
                                      Visibility="Collapsed"
                                      IsOpen="True"
                                      IsClosable="False"
                                      Severity="Informational"
                                      Title="Analyzer ready"
                                      Message="Choose a detected or manual file path to inspect save structure, options state, and comparison data." />

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource SavesSectionCardStyle}"
                            CornerRadius="0,14,14,0"
                            BorderThickness="0,1,1,1">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="AnalyzerTitleTextBlock"
                                               Text="Save Analyzer"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="AnalyzerModeTextBlock"
                                               Text="Single-file analysis: choose a .bes or .bea file to inspect."
                                               FontSize="12"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric1LabelTextBlock" Text="File Kind" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric1ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric1DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric2LabelTextBlock" Text="Missions" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric2ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric2DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric3LabelTextBlock" Text="Goodies" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric3ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric3DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric4LabelTextBlock" Text="Kill Total" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric4ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric4DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric5LabelTextBlock" Text="Tech Slots" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric5ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric5DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,12,0,0"
                            Style="{StaticResource SavesSectionCardStyle}"
                            VerticalAlignment="Stretch">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Report workspace"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button x:Name="CopyReportButton"
                                            Content="Copy report"
                                            Click="CopyReportButton_Click"
                                            IsEnabled="False" />
                                    <Button Content="Clear"
                                            Click="ClearButton_Click" />
                                </StackPanel>
                            </Grid>
                            <TextBox x:Name="ReportTextBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     MinHeight="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="SaveEditorTabContentGrid"
                  Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:InfoBar x:Name="EditorInfoBar"
                                          Visibility="Collapsed"
                                          IsOpen="True"
                                          IsClosable="False"
                                          Severity="Informational"
                                          Title="Save editor common path"
                                          Message="Patch career progression, goodies, links, mission ranks, and kill counts here. Startup settings and keybind overrides stay in Configuration Editor." />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="File selection"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Work against `.bes` career saves only. `defaultoptions.bea` remains in Configuration Editor because it controls the boot-time global settings snapshot."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <ComboBox x:Name="EditorDetectedFilesComboBox"
                                              Header="Detected career saves"
                                              PlaceholderText="No detected career saves yet"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="EditorDetectedFilesComboBox_SelectionChanged" />
                                    <TextBlock x:Name="EditorDetectedFilesStatusTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Button Content="Refresh detected saves"
                                            Click="RefreshEditorDetectedFilesButton_Click"
                                            HorizontalAlignment="Left" />
                                    <TextBox x:Name="EditorInputFileTextBox"
                                             Header="Input save"
                                             TextChanged="EditorPathTextBox_TextChanged" />
                                    <TextBox x:Name="EditorOutputFileTextBox"
                                             Header="Output save"
                                             TextChanged="EditorPathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Browse input"
                                                Click="BrowseEditorInputButton_Click" />
                                        <Button Grid.Column="1"
                                                Content="Browse output"
                                                Click="BrowseEditorOutputButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Quick patch defaults"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Set the broad patch behavior here first. Advanced mission and per-category overrides stay below."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <ComboBox x:Name="EditorPatchPresetComboBox"
                                              Header="Patch preset"
                                              SelectionChanged="EditorPatchPresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Quick Unlock" Tag="QUICK" />
                                        <ComboBoxItem Content="Safe Edit" Tag="SAFE" />
                                        <ComboBoxItem Content="Custom" Tag="CUSTOM" />
                                    </ComboBox>
                                    <ComboBox x:Name="EditorRankComboBox"
                                              Header="Mission rank baseline"
                                              SelectionChanged="EditorQuickSettingSelectionChanged">
                                        <ComboBoxItem Content="S" Tag="S" />
                                        <ComboBoxItem Content="A" Tag="A" />
                                        <ComboBoxItem Content="B" Tag="B" />
                                        <ComboBoxItem Content="C" Tag="C" />
                                        <ComboBoxItem Content="D" Tag="D" />
                                        <ComboBoxItem Content="E" Tag="E" />
                                        <ComboBoxItem Content="No Grade" Tag="NONE" />
                                    </ComboBox>
                                    <ToggleSwitch x:Name="EditorGoodiesAsNewToggle"
                                                  Header="Mark goodies as NEW"
                                                  OnContent="Gold NEW"
                                                  OffContent="Blue OLD"
                                                  Toggled="EditorQuickSettingToggled" />
                                    <controls:NumberBox x:Name="EditorGlobalKillNumberBox"
                                                        Header="Default kill value for checked kill patching"
                                                        Minimum="0"
                                                        Maximum="16777215"
                                                        SmallChange="25"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="EditorGlobalKillNumberBox_ValueChanged" />
                                    <TextBlock x:Name="EditorKillBaselineSummaryTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Patch sections"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Keep the common path explicit: choose only the save regions you want rewritten."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <Grid ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <CheckBox x:Name="EditorPatchNodesCheckBox"
                                              Content="Patch missions"
                                              Checked="EditorPatchSectionCheckBox_Changed"
                                              Unchecked="EditorPatchSectionCheckBox_Changed" />
                                    <CheckBox x:Name="EditorPatchLinksCheckBox"
                                              Grid.Column="1"
                                              Content="Patch links"
                                              Checked="EditorPatchSectionCheckBox_Changed"
                                              Unchecked="EditorPatchSectionCheckBox_Changed" />
                                    <CheckBox x:Name="EditorPatchGoodiesCheckBox"
                                              Grid.Column="2"
                                              Content="Patch goodies"
                                              Checked="EditorPatchSectionCheckBox_Changed"
                                              Unchecked="EditorPatchSectionCheckBox_Changed" />
                                    <CheckBox x:Name="EditorPatchKillsCheckBox"
                                              Grid.Row="1"
                                              Content="Patch kill counts"
                                              Checked="EditorPatchSectionCheckBox_Changed"
                                              Unchecked="EditorPatchSectionCheckBox_Changed" />
                                    <CheckBox x:Name="EditorKillsOnlyCheckBox"
                                              Grid.Row="1"
                                              Grid.Column="1"
                                              Content="Kills only"
                                              Checked="EditorKillsOnlyCheckBox_Changed"
                                              Unchecked="EditorKillsOnlyCheckBox_Changed" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Advanced save overrides"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Keep these deeper controls visible in the normal page flow so mission-rank and kill overrides remain part of the same editing workspace."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>

                                <Border Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Per-mission rank overrides"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <Button Grid.Column="1"
                                                    Content="Set all to default"
                                                    Margin="8,0,0,0"
                                                    Click="EditorSetMissionRanksToDefaultButton_Click" />
                                            <Button Grid.Column="2"
                                                    Content="Clear"
                                                    Margin="8,0,0,0"
                                                    Click="EditorClearMissionRanksButton_Click" />
                                        </Grid>
                                        <TextBlock Text="Leave a row on Keep to use the default rank above. These overrides still run through the node patch pass, so `Patch missions` must stay enabled."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <ItemsControl x:Name="EditorMissionRanksListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,8,0,8">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="160" />
                                                                <ColumnDefinition Width="160" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding NodeLabel}"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding MissionLabel}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="WrapWholeWords" />
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding CurrentRank}"
                                                                       VerticalAlignment="Center"
                                                                       Style="{StaticResource SectionBodyTextStyle}" />
                                                            <ComboBox Grid.Column="3"
                                                                      ItemsSource="{Binding RankChoices}"
                                                                      SelectedItem="{Binding SelectedRank, Mode=TwoWay}"
                                                                      SelectionChanged="EditorMissionRankOverrideComboBox_SelectionChanged" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Per-category kill overrides"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="These overrides stay inline with the rest of the save-editing flow so category counts read as a separate section instead of a hidden follow-up."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <ItemsControl x:Name="EditorCategoryKillsListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,8,0,8">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="260" />
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="110" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0"
                                                                        Spacing="2">
                                                                <TextBlock Text="{Binding CategoryName}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding ThresholdLabel}"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding CurrentValue}"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center" />
                                                            <CheckBox Grid.Column="2"
                                                                      Content="Write"
                                                                      IsChecked="{Binding OverrideEnabled, Mode=TwoWay}"
                                                                      VerticalAlignment="Center"
                                                                      Checked="EditorCategoryKillOverrideCheckBox_Changed"
                                                                      Unchecked="EditorCategoryKillOverrideCheckBox_Changed" />
                                                            <controls:NumberBox Grid.Column="3"
                                                                                Header="Override value"
                                                                                Value="{Binding OverrideValue, Mode=TwoWay}"
                                                                                SpinButtonPlacementMode="Inline"
                                                                                Minimum="0"
                                                                                Maximum="16777215"
                                                                                SmallChange="5"
                                                                                IsEnabled="{Binding OverrideEnabled}"
                                                                                ValueChanged="EditorCategoryKillNumberBox_ValueChanged" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.35*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Patch summary"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="EditorPendingChangesTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="No pending save changes selected yet." />
                                    <TextBlock x:Name="EditorSafetyHintTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="Choose at least one section and a valid `.bes` input/output pair to enable patching." />
                                    <Button x:Name="EditorPatchButton"
                                            Content="Patch Save"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="EditorPatchButton_Click"
                                            HorizontalAlignment="Left"
                                            MinWidth="180" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Patch output"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="1"
                                                x:Name="EditorCopyOutputButton"
                                                Content="Copy"
                                                Click="EditorCopyOutputButton_Click"
                                                IsEnabled="False" />
                                    </Grid>
                                    <TextBox x:Name="EditorOutputTextBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="220"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ConfigurationEditorTabContentGrid"
                  Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:InfoBar x:Name="ConfigurationInfoBar"
                                          Visibility="Collapsed"
                                          IsOpen="True"
                                          IsClosable="False"
                                          Severity="Informational"
                                          Title="Global options editor"
                                          Message="Patch the authoritative boot-time `.bea` / `defaultoptions.bea` workflow here. Career progress stays disabled on purpose." />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="File selection"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Target boot-time global options snapshots here. In-place `.bea` patching is allowed and creates a timestamped `.bak` first."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <ComboBox x:Name="ConfigurationDetectedFilesComboBox"
                                              Header="Detected options files"
                                              PlaceholderText="No detected options files yet"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="ConfigurationDetectedFilesComboBox_SelectionChanged" />
                                    <TextBlock x:Name="ConfigurationDetectedFilesStatusTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Button Content="Refresh detected options"
                                            Click="RefreshConfigurationDetectedFilesButton_Click"
                                            HorizontalAlignment="Left" />
                                    <TextBox x:Name="ConfigurationInputFileTextBox"
                                             Header="Input options file"
                                             TextChanged="ConfigurationPathTextBox_TextChanged" />
                                    <TextBox x:Name="ConfigurationOutputFileTextBox"
                                             Header="Output options file"
                                             TextChanged="ConfigurationPathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Browse input"
                                                Click="BrowseConfigurationInputButton_Click" />
                                        <Button Grid.Column="1"
                                                Content="Browse output"
                                                Click="BrowseConfigurationOutputButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Current snapshot"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ConfigurationCurrentSettingsTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Name="ConfigurationCurrentTailTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Audio overrides"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <ToggleSwitch x:Name="ConfigurationOverrideSoundVolumeToggle"
                                                  Header="Override sound volume"
                                                  OffContent="Preserve"
                                                  OnContent="Write value"
                                                  Toggled="ConfigurationOverrideToggle_Toggled" />
                                    <controls:NumberBox x:Name="ConfigurationSoundVolumeNumberBox"
                                                        Header="Sound volume"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        SmallChange="0.05"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="ConfigurationNumberBox_ValueChanged" />
                                    <ToggleSwitch x:Name="ConfigurationOverrideMusicVolumeToggle"
                                                  Header="Override music volume"
                                                  OffContent="Preserve"
                                                  OnContent="Write value"
                                                  Toggled="ConfigurationOverrideToggle_Toggled" />
                                    <controls:NumberBox x:Name="ConfigurationMusicVolumeNumberBox"
                                                        Header="Music volume"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        SmallChange="0.05"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="ConfigurationNumberBox_ValueChanged" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Control and device overrides"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <Grid ColumnSpacing="12"
                                          RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ComboBox x:Name="ConfigurationInvertWalkerP1ComboBox"
                                                  Header="Invert Y Walker (P1)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertWalkerP2ComboBox"
                                                  Grid.Column="1"
                                                  Header="Invert Y Walker (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertFlightP1ComboBox"
                                                  Grid.Row="1"
                                                  Header="Invert Y Flight (P1)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertFlightP2ComboBox"
                                                  Grid.Row="1"
                                                  Grid.Column="1"
                                                  Header="Invert Y Flight (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationVibrationP1ComboBox"
                                                  Grid.Row="2"
                                                  Header="Vibration (P1)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationVibrationP2ComboBox"
                                                  Grid.Row="2"
                                                  Grid.Column="1"
                                                  Header="Vibration (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <TextBox x:Name="ConfigurationControllerConfigP1TextBox"
                                                 Grid.Row="3"
                                                 Header="Controller config (P1)"
                                                 TextChanged="ConfigurationControllerConfigTextBox_TextChanged" />
                                        <TextBox x:Name="ConfigurationControllerConfigP2TextBox"
                                                 Grid.Row="3"
                                                 Grid.Column="1"
                                                 Header="Controller config (P2)"
                                                 TextChanged="ConfigurationControllerConfigTextBox_TextChanged" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Copy settings from another file"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Use this when you want to transplant bindings or the raw options tail from another `.bes` or `.bea`."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBox x:Name="ConfigurationCopySourceTextBox"
                                         Header="Copy source (.bes or .bea)"
                                         TextChanged="ConfigurationCopySourceTextBox_TextChanged" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="Browse source"
                                            Click="BrowseConfigurationCopySourceButton_Click" />
                                    <Button Grid.Column="1"
                                            Content="Clear source"
                                            Click="ClearConfigurationCopySourceButton_Click" />
                                </Grid>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="20">
                                    <CheckBox x:Name="ConfigurationCopyOptionsEntriesCheckBox"
                                              Content="Copy options entries (bindings)"
                                              Checked="ConfigurationOverrideToggle_Toggled"
                                              Unchecked="ConfigurationOverrideToggle_Toggled" />
                                    <CheckBox x:Name="ConfigurationCopyOptionsTailCheckBox"
                                              Content="Copy options tail snapshot"
                                              Checked="ConfigurationOverrideToggle_Toggled"
                                              Unchecked="ConfigurationOverrideToggle_Toggled" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Advanced keybind overrides"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Keep the keybind override grid in the main page flow so it behaves like the rest of the configuration workspace instead of disappearing behind a dropdown."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Keybind overrides"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="1"
                                                Content="Load input"
                                                Margin="8,0,0,0"
                                                Click="LoadConfigurationKeybindsFromInputButton_Click" />
                                        <Button Grid.Column="2"
                                                Content="Load copy source"
                                                Margin="8,0,0,0"
                                                Click="LoadConfigurationKeybindsFromCopySourceButton_Click" />
                                        <Button Grid.Column="3"
                                                Content="Clear"
                                                Margin="8,0,0,0"
                                                Click="ClearConfigurationKeybindsButton_Click" />
                                    </Grid>
                                    <TextBlock x:Name="ConfigurationKeybindHintTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                    <ListView x:Name="ConfigurationKeybindListView"
                                              SelectionMode="None"
                                              IsItemClickEnabled="False"
                                              MinHeight="360"
                                              MaxHeight="460">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,10,0,10">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="280" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Spacing="2">
                                                            <TextBlock Text="{Binding GroupLabel}"
                                                                       Opacity="0.68"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding ActionLabel}"
                                                                       FontWeight="SemiBold" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="Current P1:"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                                <TextBlock Text="{Binding CurrentPlayer1Token}"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="Current P2:"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                                <TextBlock Text="{Binding CurrentPlayer2Token}"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBox Grid.Column="1"
                                                                 Header="Player 1 override"
                                                                 Text="{Binding Player1Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="ConfigurationKeybindTextBox_TextChanged" />
                                                        <TextBox Grid.Column="2"
                                                                 Header="Player 2 override"
                                                                 Text="{Binding Player2Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="ConfigurationKeybindTextBox_TextChanged" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.35*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Patch summary"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ConfigurationPendingChangesTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock x:Name="ConfigurationSafetyHintTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Button x:Name="ConfigurationPatchButton"
                                            Content="Patch Configuration"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="ConfigurationPatchButton_Click"
                                            HorizontalAlignment="Left"
                                            MinWidth="200" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Patch output"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="1"
                                                x:Name="ConfigurationCopyOutputButton"
                                                Content="Copy"
                                                Click="ConfigurationCopyOutputButton_Click"
                                                IsEnabled="False" />
                                    </Grid>
                                    <TextBox x:Name="ConfigurationOutputTextBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="220"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
