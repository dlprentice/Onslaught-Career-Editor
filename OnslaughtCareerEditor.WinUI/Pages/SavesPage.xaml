                                                                      VerticalAlignment="Center"
                                                                      Checked="EditorCategoryKillOverrideCheckBox_Changed"
                                                                      Unchecked="EditorCategoryKillOverrideCheckBox_Changed" />
                                                            <controls:NumberBox Grid.Column="3"
                                                                                AutomationProperties.Name="{Binding CategoryName}"
                                                                                Header="Override value"
                                                                                Value="{Binding OverrideValue, Mode=TwoWay}"
                                                                                SpinButtonPlacementMode="Inline"
                                                                                Minimum="0"
                                                                                Maximum="16777215"
                                                                                SmallChange="5"
                                                                                IsEnabled="{Binding OverrideEnabled}"
                                                                                ValueChanged="EditorCategoryKillNumberBox_ValueChanged" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                  </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.35*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Patch summary"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="EditorPendingChangesTextBlock"
                                               AutomationProperties.AutomationId="SaveEditorPendingChanges"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="No pending save changes selected yet." />
                                    <TextBlock x:Name="EditorSafetyHintTextBlock"
                                               AutomationProperties.AutomationId="SaveEditorSafetyHint"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               Text="Choose at least one section and a valid .bes input/output pair to enable patching." />
                                    <Button x:Name="EditorPatchButton"
                                            AutomationProperties.AutomationId="SaveEditorPatchButton"
                                            Content="Write patched save copy"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="EditorPatchButton_Click"
                                            HorizontalAlignment="Left"
                                            MinWidth="180" />
                                    <Button x:Name="SaveEditorShowWrittenSaveButton"
                                            AutomationProperties.AutomationId="SaveEditorShowWrittenSaveButton"
                                            AutomationProperties.Name="Show written save in File Explorer"
                                            Content="Show written save in File Explorer"
                                            Click="SaveEditorShowWrittenSaveButton_Click"
                                            IsEnabled="False"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Patch output"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="1"
                                                x:Name="EditorCopyOutputButton"
                                                AutomationProperties.AutomationId="SaveEditorCopyOutputButton"
                                                Content="Copy"
                                                Click="EditorCopyOutputButton_Click"
                                                IsEnabled="False" />
                                    </Grid>
                                    <TextBox x:Name="EditorOutputTextBox"
                                             AutomationProperties.AutomationId="SaveEditorOutputLog"
                                             AutomationProperties.Name="Save editor output log"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="220"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ConfigurationEditorTabContentGrid"
                  Visibility="Collapsed">
                <ScrollViewer AutomationProperties.AutomationId="ConfigurationEditorScrollViewer"
                              AutomationProperties.Name="Game options workflow"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:InfoBar x:Name="ConfigurationInfoBar"
                                          AutomationProperties.AutomationId="ConfigurationStatusInfo"
                                          Visibility="Visible"
                                          IsOpen="True"
                                          IsClosable="False"
                                          Severity="Informational"
                                          Title="Game options"
                                          Message="Edit startup options, audio levels, and controls from a .bea options file. Career progress stays in Save Editor." />

                        <Border AutomationProperties.AutomationId="ModernControllerSetupCard"
                                Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock AutomationProperties.AutomationId="ModernControllerSetupHeading"
                                           AutomationProperties.HeadingLevel="Level2"
                                           Text="Modern controller setup"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock AutomationProperties.AutomationId="ModernControllerSetupSteps"
                                           Text="1. In Steam Input, select Aquila - Gamepad with Mouse Aiming.&#x0a;2. In the game's Controller Options, bind the buttons, then map left-stick up to Movement: Forward so the movement directions are assigned.&#x0a;3. Lower the game's mouse sensitivity to minimum. Adjust walking and flying inversion there if needed."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock AutomationProperties.AutomationId="ModernControllerSetupBoundary"
                                           Text="The Toolkit can edit a copied options file. It does not configure Steam Input, detect your connected controller, or prove improved control feel."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <Button AutomationProperties.AutomationId="OpenZigguratControllerGuideButton"
                                        AutomationProperties.Name="Open Ziggurat's Steam setup guide in browser"
