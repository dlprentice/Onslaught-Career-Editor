                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="1"
                                                AutomationProperties.AutomationId="ConfigurationLoadKeybindsFromInputButton"
                                                Content="Load input"
                                                Margin="8,0,0,0"
                                                Click="LoadConfigurationKeybindsFromInputButton_Click" />
                                        <Button Grid.Column="2"
                                                AutomationProperties.AutomationId="ConfigurationLoadKeybindsFromCopySourceButton"
                                                Content="Load copy source"
                                                Margin="8,0,0,0"
                                                Click="LoadConfigurationKeybindsFromCopySourceButton_Click" />
                                        <Button Grid.Column="3"
                                                AutomationProperties.AutomationId="ConfigurationClearKeybindsButton"
                                                Content="Clear"
                                                Margin="8,0,0,0"
                                                Click="ClearConfigurationKeybindsButton_Click" />
                                    </Grid>
                                    <TextBlock x:Name="ConfigurationKeybindHintTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
