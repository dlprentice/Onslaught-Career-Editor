                                    <ToggleSwitch x:Name="ConfigurationOverrideMusicVolumeToggle"
                                                  AutomationProperties.AutomationId="ConfigurationOverrideMusicVolumeToggle"
                                                  Header="Override music volume"
                                                  OffContent="Preserve"
                                                  OnContent="Write value"
                                                  Toggled="ConfigurationOverrideToggle_Toggled" />
                                    <controls:NumberBox x:Name="ConfigurationMusicVolumeNumberBox"
                                                        AutomationProperties.AutomationId="ConfigurationMusicVolumeNumberBox"
                                                        Header="Music volume"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        SmallChange="0.05"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="ConfigurationNumberBox_ValueChanged" />
                                </StackPanel>
