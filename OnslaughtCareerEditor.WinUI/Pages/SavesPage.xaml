                                                    Click="EditorSetMissionRanksToDefaultButton_Click" />
                                            <Button Grid.Column="2"
                                                    AutomationProperties.AutomationId="SaveEditorClearMissionRanksButton"
                                                    Content="Clear"
                                                    Margin="8,0,0,0"
                                                    Click="EditorClearMissionRanksButton_Click" />
                                        </Grid>
