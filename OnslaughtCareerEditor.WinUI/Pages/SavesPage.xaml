                                            <DataTemplate>
                                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,10,0,10">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="280" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Spacing="2">
                                                            <TextBlock Text="{Binding GroupLabel}"
                                                                       Opacity="0.68"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding ActionLabel}"
                                                                       FontWeight="SemiBold" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="Current P1:"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                                <TextBlock Text="{Binding CurrentPlayer1Token}"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="Current P2:"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                                <TextBlock Text="{Binding CurrentPlayer2Token}"
                                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                         <TextBox Grid.Column="1"
                                                                  AutomationProperties.Name="{Binding Player1AccessibleName}"
                                                                  Header="Player 1 override"
                                                                  Text="{Binding Player1Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  TextChanged="ConfigurationKeybindTextBox_TextChanged" />
                                                         <TextBox Grid.Column="2"
                                                                  AutomationProperties.Name="{Binding Player2AccessibleName}"
                                                                  Header="Player 2 override"
                                                                  Text="{Binding Player2Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  TextChanged="ConfigurationKeybindTextBox_TextChanged" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.35*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Patch summary"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ConfigurationPendingChangesTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock x:Name="ConfigurationSafetyHintTextBlock"
                                               AutomationProperties.AutomationId="ConfigurationSafetyHint"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Button x:Name="ConfigurationPatchButton"
                                            AutomationProperties.AutomationId="ConfigurationPatchButton"
                                            Content="Write options copy"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="ConfigurationPatchButton_Click"
                                            HorizontalAlignment="Left"
                                            MinWidth="200" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Patch output"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="1"
                                                x:Name="ConfigurationCopyOutputButton"
                                                AutomationProperties.AutomationId="ConfigurationCopyOutputButton"
                                                Content="Copy"
                                                Click="ConfigurationCopyOutputButton_Click"
                                                IsEnabled="False" />
                                    </Grid>
                                    <TextBox x:Name="ConfigurationOutputTextBox"
                                             AutomationProperties.AutomationId="ConfigurationOutputLog"
                                             AutomationProperties.Name="Game options output log"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="220"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
