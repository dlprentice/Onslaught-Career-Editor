                                                 Grid.Row="3"
                                                 Grid.Column="1"
                                                 Header="Controller config (P2)"
                                                 TextChanged="ConfigurationControllerConfigTextBox_TextChanged" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

