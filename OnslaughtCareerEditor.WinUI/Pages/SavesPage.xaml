                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="File selection"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
