<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.SavesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="SavesTabButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabButtonBaseStyle}" />
        <Style x:Key="SavesInactiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabInactiveButtonStyle}" />
        <Style x:Key="SavesActiveTabButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SubTabActiveButtonStyle}" />
        <Style x:Key="SavesSectionCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="SavesMetricCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SavesSectionCardStyle}">
            <Setter Property="Background" Value="{ThemeResource ShellMetricSurfaceBrush}" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Page.Resources>

    <Grid Padding="20,18,20,18"
          RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,14"
                    Spacing="6">
            <TextBlock Text="Save Lab"
                       AutomationProperties.AutomationId="SavesPageTitle"
                       AutomationProperties.HeadingLevel="Level1"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="Inspect your career saves and options files, then make safe edits. The app preserves everything it does not change and writes patches to a separate file."
                       Style="{StaticResource SectionBodyTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource SavesSectionCardStyle}"
                Margin="0,0,0,12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Text="1. Inspect a file"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Start here when you want to understand a save or options snapshot before making any change."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Button x:Name="AnalyzeTaskButton"
                            AutomationProperties.AutomationId="AnalyzeTaskButton"
                            Content="Analyze a save"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="AnalyzeTaskButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="8">
                    <TextBlock Text="2. Edit a copied save"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Use the normal career-save workflow for unlocks, ranks, goodies, and kill counts."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Button AutomationProperties.AutomationId="EditSaveTaskButton"
                            Content="Open save editor"
                            HorizontalAlignment="Left"
                            Click="EditSaveTaskButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="8">
                    <TextBlock Text="3. Edit game options"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Edit startup settings, audio levels, and controller bindings from defaultoptions.bea, separate from career progress in .bes saves."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Button AutomationProperties.AutomationId="ConfigureOptionsTaskButton"
                            AutomationProperties.Name="Open Game Options"
                            Content="Open Game Options"
                            HorizontalAlignment="Left"
                            Click="ConfigureOptionsTaskButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SubTabStripBorderStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button x:Name="SaveAnalyzerTabButton"
                        AutomationProperties.AutomationId="SaveAnalyzerTabButton"
                        Content="Save Analyzer"
                        Click="SaveAnalyzerTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
                <Button x:Name="SaveEditorTabButton"
                        AutomationProperties.AutomationId="SaveEditorTabButton"
                        Content="Save Editor"
                        Click="SaveEditorTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
                <Button x:Name="ConfigurationEditorTabButton"
                        AutomationProperties.AutomationId="ConfigurationEditorTabButton"
                        Content="Game Options"
                        Click="ConfigurationEditorTabButton_Click"
                        Style="{StaticResource SavesInactiveTabButtonStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid x:Name="SaveAnalyzerTabContentGrid"
                  Visibility="Visible">
                <Grid ColumnSpacing="0"
                      RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource SavesSectionCardStyle}"
                            CornerRadius="14,0,0,14"
                            BorderThickness="1,1,0,1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Detected files"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Pick from detected save and options files, or refresh after changing the game directory in Settings."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <ComboBox x:Name="DetectedFilesComboBox"
                                      AutomationProperties.AutomationId="SaveAnalyzerDetectedFilesComboBox"
                                      PlaceholderText="No detected files yet"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="DetectedFilesComboBox_SelectionChanged" />
                            <Button x:Name="RefreshDetectedFilesButton"
                                    AutomationProperties.AutomationId="SaveAnalyzerRefreshDetectedFilesButton"
                                    Content="Refresh detected files"
                                    Click="RefreshDetectedFilesButton_Click" />
                            <TextBlock x:Name="DetectedFilesStatusTextBlock"
                                       Style="{StaticResource SectionBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="0"
                                  AutomationProperties.AutomationId="SaveAnalyzerResultsScrollViewer"
                                  AutomationProperties.Name="Save analyzer results"
                                  Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12">
                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Analyze a file"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FilePathTextBox"
                                             AutomationProperties.AutomationId="SaveAnalyzerFilePath"
                                             Header="Input file"
                                             TextChanged="FilePathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Browse"
                                                AutomationProperties.AutomationId="SaveAnalyzerBrowseInputButton"
                                                AutomationProperties.Name="Browse input file"
                                                Click="BrowseFileButton_Click" />
                                        <Button x:Name="AnalyzeButton"
                                                AutomationProperties.AutomationId="SaveAnalyzerAnalyzeButton"
                                                Grid.Column="1"
                                                Content="Analyze / Reload"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Click="AnalyzeButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Display options"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <ToggleSwitch x:Name="VerboseToggle"
                                                  AutomationProperties.AutomationId="SaveAnalyzerVerboseToggle"
                                                  Header="Verbose output"
                                                  OffContent="Summary report"
                                                  OnContent="Nodes and bindings"
                                                  Toggled="DisplayOption_Toggled" />
                                    <ToggleSwitch x:Name="DumpMysteryToggle"
                                                  AutomationProperties.AutomationId="SaveAnalyzerReservedBytesToggle"
                                                  Header="Advanced byte details"
                                                  OffContent="Keep compact"
                                                  OnContent="Show troubleshooting details"
                                                  Toggled="DisplayOption_Toggled" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Compare files"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="CompareFilePathTextBox"
                                             AutomationProperties.AutomationId="SaveAnalyzerCompareFilePath"
                                             Header="Compare against"
                                             TextChanged="CompareFilePathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Browse"
                                                AutomationProperties.AutomationId="SaveAnalyzerBrowseCompareButton"
                                                AutomationProperties.Name="Browse compare file"
                                                Click="BrowseCompareFileButton_Click" />
                                        <Button x:Name="CompareButton"
                                                AutomationProperties.AutomationId="SaveAnalyzerCompareButton"
                                                Grid.Column="1"
                                                Content="Compare files"
                                                Click="CompareButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SavesSectionCardStyle}">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="SummaryTitleTextBlock"
                                               AutomationProperties.AutomationId="SaveAnalyzerSummaryTitle"
                                               Text="Analysis summary"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <controls:TreeView x:Name="SummaryTreeView"
                                                       AutomationProperties.AutomationId="SaveAnalyzerSummaryTree"
                                                       AutomationProperties.Name="Analysis summary tree"
                                                       Grid.Row="1"
                                                       MinHeight="180"
                                                       MaxHeight="280">
                                        <controls:TreeView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="WrapWholeWords"
                                                           MaxWidth="250" />
                                            </DataTemplate>
                                        </controls:TreeView.ItemTemplate>
                                    </controls:TreeView>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="{ThemeResource ShellSurfaceBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            BorderThickness="0,1,0,1"
                            CornerRadius="0" />

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource SavesSectionCardStyle}"
                            CornerRadius="0,14,14,0"
                            BorderThickness="0,1,1,1">
                        <StackPanel Spacing="10">
                            <controls:InfoBar x:Name="AnalyzerInfoBar"
                                              AutomationProperties.AutomationId="SaveAnalyzerStatusInfo"
                                              Visibility="Visible"
                                              IsOpen="True"
                                              IsClosable="False"
                                              Severity="Informational"
                                              Title="Analyzer ready"
                                              Message="Choose a detected or manual file path to inspect save structure, options state, and comparison data." />

                            <Border x:Name="AnalyzerEmptyStateBorder"
                                    Style="{StaticResource SavesMetricCardStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Choose a file to see save facts"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Pick a detected save or options file on the left. The analyzer will replace this prompt with file kind, mission, goodie, kill, and tech-slot summaries."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Grid x:Name="AnalyzerHeaderGrid"
                                  Visibility="Collapsed"
                                  MaxHeight="0"
                                  Opacity="0"
                                  ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="AnalyzerTitleTextBlock"
                                               AutomationProperties.AutomationId="SaveAnalyzerDocumentTitle"
                                               Text="Save Analyzer"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="AnalyzerModeTextBlock"
                                               Text="Single-file analysis: choose a .bes or .bea file to inspect."
                                               FontSize="12"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="AnalyzerMetricsGrid"
                                  Visibility="Collapsed"
                                  MaxHeight="0"
                                  Opacity="0"
                                  ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric1LabelTextBlock" Text="File Kind" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric1ValueTextBlock"
                                                   AutomationProperties.AutomationId="SaveAnalyzerFileKindMetric"
                                                   Text="--"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric1DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric2LabelTextBlock" Text="Missions" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric2ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric2DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric3LabelTextBlock" Text="Goodies" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric3ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric3DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric4LabelTextBlock" Text="Kill Total" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric4ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric4DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4"
                                        Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="Metric5LabelTextBlock" Text="Tech Slots" FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBlock x:Name="Metric5ValueTextBlock" Text="--" FontSize="22" FontWeight="SemiBold" />
                                        <TextBlock x:Name="Metric5DetailTextBlock" Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,12,0,0"
                            Style="{StaticResource SavesSectionCardStyle}"
                            VerticalAlignment="Stretch">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Report workspace"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button x:Name="CopyReportButton"
                                            AutomationProperties.AutomationId="SaveAnalyzerCopyReportButton"
                                            Content="Copy report"
                                            Click="CopyReportButton_Click"
                                            IsEnabled="False" />
                                    <Button Content="Clear"
                                            AutomationProperties.AutomationId="SaveAnalyzerClearReportButton"
                                            Click="ClearButton_Click" />
                                </StackPanel>
                            </Grid>
                            <TextBox x:Name="ReportTextBox"
                                     AutomationProperties.AutomationId="SaveAnalyzerReport"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     PlaceholderText="Analysis report appears here after you choose a save or options file."
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     MinHeight="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="SaveEditorTabContentGrid"
                  Visibility="Collapsed">
                <ScrollViewer AutomationProperties.AutomationId="SaveEditorScrollViewer"
                              AutomationProperties.Name="Save editor workflow"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:InfoBar x:Name="EditorInfoBar"
                                          AutomationProperties.AutomationId="SaveEditorResultInfo"
                                          Visibility="Collapsed"
                                          IsOpen="True"
                                          IsClosable="False"
                                          Severity="Informational"
                                          Title="Save editor common path"
                                          Message="Edit career progress, goodies, mission ranks, and kills here. Startup settings, audio levels, and controls are in Game Options." />

                        <Border x:Name="SaveEditorFirstSaveGuide"
                                AutomationProperties.AutomationId="SaveEditorFirstSaveGuide"
                                Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Your first copied save"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock Text="1. Choose an existing .bes career save.  2. Keep the separate suggested output.  3. Choose at least one change and review Pending changes.  4. Write the copied save."
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Text="The Toolkit writes a separate file and does not install it. After a successful write, close the copied game, back up any save you replace, then manually copy the new file into a Safe Game Copy's savegames folder."
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock x:Name="SaveEditorFirstSaveStatus"
                                           AutomationProperties.AutomationId="SaveEditorFirstSaveStatus"
                                           AutomationProperties.LiveSetting="Polite"
                                           FontWeight="SemiBold"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="File selection"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Work against .bes career saves only. defaultoptions.bea is handled in Game Options because it controls startup settings."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <ComboBox x:Name="EditorDetectedFilesComboBox"
                                              AutomationProperties.AutomationId="SaveEditorDetectedFiles"
                                              Header="Detected career saves"
                                              PlaceholderText="No detected career saves yet"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="EditorDetectedFilesComboBox_SelectionChanged" />
                                    <TextBlock x:Name="EditorDetectedFilesStatusTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Button Content="Refresh detected saves"
                                            AutomationProperties.AutomationId="SaveEditorRefreshDetectedSavesButton"
                                            Click="RefreshEditorDetectedFilesButton_Click"
                                            HorizontalAlignment="Left" />
                                    <TextBox x:Name="EditorInputFileTextBox"
                                             AutomationProperties.AutomationId="SaveEditorInputFile"
                                             Header="Input save"
                                             TextChanged="EditorPathTextBox_TextChanged" />
                                    <TextBox x:Name="EditorOutputFileTextBox"
                                             AutomationProperties.AutomationId="SaveEditorOutputFile"
                                             Header="Output save"
                                             TextChanged="EditorPathTextBox_TextChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                AutomationProperties.AutomationId="SaveEditorBrowseInputButton"
                                                Content="Browse input"
                                                Click="BrowseEditorInputButton_Click" />
                                        <Button Grid.Column="1"
                                                AutomationProperties.AutomationId="SaveEditorBrowseOutputButton"
                                                Content="Browse output"
                                                Click="BrowseEditorOutputButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SavesSectionCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Quick patch defaults"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Set the broad patch behavior here first. Advanced mission and per-category overrides stay below."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Text="Mission rank applies with Patch missions; NEW/OLD applies with Patch goodies; the kill value applies with Patch kill counts."
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                    <ComboBox x:Name="EditorPatchPresetComboBox"
                                              AutomationProperties.AutomationId="SaveEditorPatchPresetComboBox"
                                              Header="Patch preset"
                                              SelectionChanged="EditorPatchPresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Start empty — choose sections" Tag="SAFE" />
                                        <ComboBoxItem Content="Quick Unlock — all sections" Tag="QUICK" />
                                        <ComboBoxItem Content="Custom selection" Tag="CUSTOM" />
                                    </ComboBox>
                                    <ComboBox x:Name="EditorRankComboBox"
                                              AutomationProperties.AutomationId="SaveEditorRankComboBox"
                                              Header="Mission rank baseline"
                                              SelectionChanged="EditorQuickSettingSelectionChanged">
                                        <ComboBoxItem Content="S" Tag="S" />
                                        <ComboBoxItem Content="A" Tag="A" />
                                        <ComboBoxItem Content="B" Tag="B" />
                                        <ComboBoxItem Content="C" Tag="C" />
                                        <ComboBoxItem Content="D" Tag="D" />
                                        <ComboBoxItem Content="E" Tag="E" />
                                        <ComboBoxItem Content="No Grade" Tag="NONE" />
                                    </ComboBox>
                                    <ToggleSwitch x:Name="EditorGoodiesAsNewToggle"
                                                  AutomationProperties.AutomationId="SaveEditorGoodiesAsNewToggle"
                                                  Header="Mark goodies as NEW"
                                                  OnContent="Gold NEW"
                                                  OffContent="Blue OLD"
                                                  Toggled="EditorQuickSettingToggled" />
                                    <controls:NumberBox x:Name="EditorGlobalKillNumberBox"
                                                        AutomationProperties.AutomationId="SaveEditorGlobalKillNumberBox"
                                                        Header="Default kill value for checked kill patching"
                                                        Minimum="0"
                                                        Maximum="16777215"
                                                        SmallChange="25"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="EditorGlobalKillNumberBox_ValueChanged" />
                                    <TextBlock x:Name="EditorKillBaselineSummaryTextBlock"
                                               Style="{StaticResource SectionBodyTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource SavesSectionCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Focused Goodie state"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Write one documented Goodie dword without running the broad Goodies pass. IDs are zero-based. A Safe Game Copy destination must be one .bes file directly inside that verified profile's savegames folder; installed game folders and in-place output remain blocked."
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:NumberBox x:Name="EditorFocusedGoodieIdNumberBox"
                                                        AutomationProperties.AutomationId="SaveEditorFocusedGoodieIdNumberBox"
                                                        Header="Goodie ID"
                                                        Minimum="0"
                                                        Maximum="232"
                                                        SmallChange="1"
                                                        SpinButtonPlacementMode="Inline"
                                                        ValueChanged="EditorFocusedGoodieIdNumberBox_ValueChanged" />
                                    <ComboBox x:Name="EditorFocusedGoodieStateComboBox"
                                              Grid.Column="1"
                                              AutomationProperties.AutomationId="SaveEditorFocusedGoodieStateComboBox"
                                              Header="State"
                                              SelectionChanged="EditorFocusedGoodieStateComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Locked" Tag="0" />
                                        <ComboBoxItem Content="Instructions" Tag="1" />
                                        <ComboBoxItem Content="New (gold)" Tag="2" />
                                        <ComboBoxItem Content="Old (blue)" Tag="3" />
                                    </ComboBox>
                                </Grid>
                                <TextBlock x:Name="EditorFocusedGoodieStatusTextBlock"
                                           AutomationProperties.AutomationId="SaveEditorFocusedGoodieStatus"
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           TextWrapping="WrapWholeWords" />
                                <Button x:Name="EditorPatchFocusedGoodieButton"
                                        AutomationProperties.AutomationId="SaveEditorPatchFocusedGoodieButton"
                                        Content="Write focused Goodie copy"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="EditorPatchFocusedGoodieButton_Click"
                                        HorizontalAlignment="Left"
