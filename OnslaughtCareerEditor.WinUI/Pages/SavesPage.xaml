                                      IsExpanded="False">
                                <Border Style="{StaticResource SavesSectionCardStyle}">
                                  <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Advanced save overrides"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Ordinary first edits do not need these controls. Mission overrides require Patch missions; category-kill overrides require Patch kill counts. Collapsing this section keeps active values unchanged."
