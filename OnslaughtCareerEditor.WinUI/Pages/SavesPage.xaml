                                </StackPanel>

                                <Border Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Per-mission rank overrides"
                                                       AutomationProperties.AutomationId="SaveEditorMissionOverridesHeading"
