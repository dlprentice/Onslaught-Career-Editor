                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertWalkerP2ComboBox"
                                                  AutomationProperties.AutomationId="ConfigurationInvertWalkerP2ComboBox"
                                                  Grid.Column="1"
                                                  Header="Invert Y Walker (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertFlightP1ComboBox"
                                                  AutomationProperties.AutomationId="ConfigurationInvertFlightP1ComboBox"
                                                  Grid.Row="1"
                                                  Header="Invert Y Flight (P1)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationInvertFlightP2ComboBox"
                                                  AutomationProperties.AutomationId="ConfigurationInvertFlightP2ComboBox"
                                                  Grid.Row="1"
                                                  Grid.Column="1"
                                                  Header="Invert Y Flight (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationVibrationP1ComboBox"
                                                  AutomationProperties.AutomationId="ConfigurationVibrationP1ComboBox"
                                                  Grid.Row="2"
                                                  Header="Vibration (P1)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <ComboBox x:Name="ConfigurationVibrationP2ComboBox"
                                                  AutomationProperties.AutomationId="ConfigurationVibrationP2ComboBox"
                                                  Grid.Row="2"
                                                  Grid.Column="1"
                                                  Header="Vibration (P2)"
                                                  SelectionChanged="ConfigurationOptionSelectionChanged">
                                            <ComboBoxItem Content="Keep" Tag="KEEP" />
                                            <ComboBoxItem Content="On" Tag="ON" />
                                            <ComboBoxItem Content="Off" Tag="OFF" />
                                        </ComboBox>
                                        <TextBox x:Name="ConfigurationControllerConfigP1TextBox"
