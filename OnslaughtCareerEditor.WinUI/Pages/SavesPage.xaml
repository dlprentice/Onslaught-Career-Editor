                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            AutomationProperties.AutomationId="ConfigurationBrowseCopySourceButton"
                                            Content="Browse source"
                                            Click="BrowseConfigurationCopySourceButton_Click" />
                                    <Button Grid.Column="1"
                                            AutomationProperties.AutomationId="ConfigurationClearCopySourceButton"
