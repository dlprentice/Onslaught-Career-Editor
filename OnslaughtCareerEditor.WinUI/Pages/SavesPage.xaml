                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SavesMetricCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Per-category kill overrides"
                                                   AutomationProperties.AutomationId="SaveEditorCategoryKillOverridesHeading"
                                                   AutomationProperties.HeadingLevel="Level3"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="These overrides stay inline with the rest of the save-editing flow so category counts read as a separate section instead of a hidden follow-up."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <ItemsControl x:Name="EditorCategoryKillsListView"
                                                      AutomationProperties.AutomationId="EditorCategoryKillsListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,8,0,8">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="260" />
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="110" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0"
                                                                        Spacing="2">
                                                                <TextBlock Text="{Binding CategoryName}"
                                                                           FontWeight="SemiBold" />
