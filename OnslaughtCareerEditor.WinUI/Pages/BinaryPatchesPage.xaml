                                                                                    Margin="10,0,0,0">
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       FontWeight="SemiBold"
                                                                                       TextWrapping="WrapWholeWords" />
                                                                            <TextBlock Text="{Binding Summary}"
                                                                                       Style="{StaticResource SectionBodyTextStyle}" />
