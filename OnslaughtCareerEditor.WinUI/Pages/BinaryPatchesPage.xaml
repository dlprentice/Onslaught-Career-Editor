<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.BinaryPatchesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OnslaughtCareerEditor.WinUI.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="PatchBenchChoiceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource ShellSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="PatchBenchChoiceSelectedButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PatchBenchChoiceButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource ShellSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ShellAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>
    <ScrollViewer AutomationProperties.AutomationId="PatchBenchScrollViewer"
                  AutomationProperties.Name="Windowed &amp; Mods workflow">
        <StackPanel Padding="20,18,20,24">
            <TextBlock Text="Windowed &amp; Mods"
                       AutomationProperties.AutomationId="BinaryPatchesPageTitle"
                       AutomationProperties.HeadingLevel="Level1"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Margin="0,6,0,14"
                       Text="A safe game copy is a separate folder this app creates from your installed game. Mods, patches, launch options, and music swaps happen there only. Your Steam install is never changed."
                       Style="{StaticResource SectionBodyTextStyle}" />
            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="What Gets Touched"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Steam/game install: read-only source. Used only to copy files; the installed game and original BEA.exe are not changed."
                                Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Safe game copy: app-owned folder. This is what Play runs."
                                Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Advanced BEA.exe-only copy: used for technical inspection and byte-level patching only. It is not a fully playable game folder."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>
            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Main workflow"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="1. Find your installed game. 2. Pick mods for a safe copy. 3. Create the safe copy. 4. Play the safe copy."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Grid ColumnSpacing="8"
                          RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PatchBenchTopUseGameFolderButton"
                                AutomationProperties.AutomationId="PatchBenchTopUseGameFolderButton"
                                AutomationProperties.Name="Use configured game folder for safe copy"
                                Content="Use configured folder"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Click="UseGameDirButton_Click" />
                        <Button x:Name="PatchBenchTopCreateSafeCopyButton"
                                AutomationProperties.AutomationId="PatchBenchTopCreateSafeCopyButton"
                                AutomationProperties.Name="Create safe game copy from main workflow"
                                Content="Create safe copy"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="PrepareCopiedProfileButton_Click" />
                        <Button x:Name="PatchBenchTopPlaySafeCopyButton"
                                AutomationProperties.AutomationId="PatchBenchTopPlaySafeCopyButton"
                                AutomationProperties.Name="Launch safe game copy from main workflow"
                                Content="Launch safe game copy"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Click="LaunchCopiedProfileButton_Click" />
                    </Grid>
                    <TextBlock Text="These shortcuts use the same guarded safe-copy workflow below; technical diagnostics stay hidden unless you choose to show them."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>
            <Border AutomationProperties.AutomationId="PatchBenchOnlinePrepCard"
                    BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="PatchBenchOnlinePrepTitle"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepTitle"
                               Text="Local split-screen safe copy"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PatchBenchOnlinePrepSummary"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepSummary"
                               Text="Local split-screen launch preset is available for testing in a safe copy."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock x:Name="PatchBenchOnlinePrepBoundary"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepBoundary"
                               Text="Prepare the known local split-screen level in a safe copy. This does not add online play."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Button x:Name="PatchBenchOnlinePrepLocalProbeButton"
                            AutomationProperties.AutomationId="PatchBenchOnlinePrepLocalProbeButton"
                            AutomationProperties.Name="Set up local split-screen test for safe copy"
                            Content="Use local split-screen launch preset"
                            HorizontalAlignment="Left"
                            Click="LocalMultiplayerProbeButton_Click" />
                    <TextBlock x:Name="PatchBenchOnlinePrepActionStatus"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepActionStatus"
                               Text="Select the local split-screen launch preset, then create and play a safe copy. This is not Host/Join."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,16"
                  ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="PatchSetBorder"
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                        <StackPanel Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Choose player mods"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                  <TextBlock Text="Every safe game copy includes the complete 28-region 16:9 aspect/FOV correction, the retail 16:9 option, and the tested 1600x900 windowed launch baseline."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Copied Level 100 gameplay was verified at 1600x900: live dimensions were 1600x900 and the runtime aspect term was 1.777778. Other resolutions, machines, and drivers are not guaranteed. The installed game stays unchanged."
                                            Margin="0,6,0,0"
                                            Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Add only the player mods you want below. Open Lab only for legacy recipes, experiments, and diagnostics."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Safe compatibility and recovery"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Enhanced Copy is the exact required base: aspect-correct 1600x900 gameplay, windowed startup, and minimum mouse sensitivity for modern mouse aiming. Optional mods are not part of this base."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PatchBenchWindowedPresetButton"
                                                AutomationProperties.AutomationId="PatchBenchWindowedPresetButton"
                                                AutomationProperties.Name="Select Enhanced Copy profile"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="WindowedPresetButton_Click">
                                            <TextBlock Text="Reset to Enhanced Copy"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                        <Button x:Name="PatchBenchClearSelectionButton"
                                                AutomationProperties.AutomationId="PatchBenchClearSelectionButton"
                                                AutomationProperties.Name="Clear optional mods; safe copies still include Enhanced Copy"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="ClearSelectionButton_Click">
                                            <TextBlock Text="Clear optional mods"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                    </Grid>
                                    <Border Background="{ThemeResource ShellSurfaceBrush}"
                                            BorderBrush="{ThemeResource ShellBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8">
                                        <TextBlock x:Name="PatchBenchSelectedProfileStatus"
                                                   AutomationProperties.AutomationId="PatchBenchSelectedProfileStatus"
                                                   AutomationProperties.Name="Selected safe-copy profile status"
                                                   Text="Selected profile: Enhanced Copy. Required 16:9 gameplay base."
                                                   TextWrapping="WrapWholeWords" />
                                    </Border>
                                    <TextBlock Text="Optional player mods"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="All player mods start off. The PATCHED marker and Goodies preview change only the copied executable. Level 100 options change only verified files inside the safe copy."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock x:Name="PatchBenchPlayerModsSelectionStatus"
                                               AutomationProperties.AutomationId="PatchBenchPlayerModsSelectionStatus"
                                               AutomationProperties.Name="Player mods selected: none."
                                               Text="Player mods selected: none."
                                               TextWrapping="WrapWholeWords" />
                                    <Grid ColumnSpacing="8"
                                          RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button AutomationProperties.AutomationId="PatchBenchAddVersionMarkerButton"
                                                AutomationProperties.Name="Add PATCHED title marker row"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Click="AddVersionMarkerButton_Click">
                                            <TextBlock Text="Add PATCHED marker"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                        <Button AutomationProperties.AutomationId="PatchBenchClearVersionMarkerButton"
                                                AutomationProperties.Name="Clear PATCHED title marker row"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Click="ClearVersionMarkerButton_Click">
                                            <TextBlock Text="Clear PATCHED marker"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                        <Button AutomationProperties.AutomationId="PatchBenchAddGoodiesPreviewButton"
                                                AutomationProperties.Name="Add bounded Goodies wall display preview; does not edit saves, award Goodies, prove every entry, or prove model and FMV playback"
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Click="AddGoodiesPreviewButton_Click">
                                            <TextBlock Text="Add Goodies wall preview"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                        <Button AutomationProperties.AutomationId="PatchBenchClearGoodiesPreviewButton"
                                                AutomationProperties.Name="Clear Goodies wall display preview row"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="56"
                                                Click="ClearGoodiesPreviewButton_Click">
                                            <TextBlock Text="Clear Goodies wall preview"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                    </Grid>
                                    <CheckBox x:Name="PatchBenchLevel100TextModOption"
                                              AutomationProperties.AutomationId="PatchBenchLevel100TextModOption"
                                              AutomationProperties.Name="Replace the first Level 100 English objective subtitle with the proven Toolkit marker"
                                              Content="Level 100 subtitle marker (English)"
                                              Checked="LaunchOptionCheckBox_Changed"
                                              Unchecked="LaunchOptionCheckBox_Changed" />
                                    <TextBlock Text="Replaces only TUTORIAL_01 with a TOOLKIT MOD ACTIVE objective line in the safe copy. Live retail proof covers this one rendered subtitle; this is not a general language importer, mission-script override, texture replacement, or AYA repacker."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <CheckBox x:Name="PatchBenchLevel100EarlyFlightModOption"
                                              AutomationProperties.AutomationId="PatchBenchLevel100EarlyFlightModOption"
                                              AutomationProperties.Name="Allow transformation as soon as Level 100 first grants control in the safe copy"
                                              Content="Level 100 early flight"
                                              Checked="LaunchOptionCheckBox_Changed"
                                              Unchecked="LaunchOptionCheckBox_Changed" />
                                    <TextBlock Text="Bypasses the tutorial's initial transformation gate in the safe copy. One verified compiled command changes from DisableFlightMode to EnableFlightMode; this is not normal Level 100 progression, loose-script loading, or a general mission editor or AYA repacker."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                </Border>

                <StackPanel Grid.Column="1"
                            Grid.Row="0"
                            Spacing="16">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Safe game copy"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Create a launchable app-owned game copy. The app applies the verified 16:9 gameplay correction, writes the copied 16:9 display option, and launches the tested 1600x900 windowed baseline; selected mods are added too. Savegames are optional, and the installed game is unchanged."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <TextBlock x:Name="PatchBenchSafeCopySourceStatus"
                                       AutomationProperties.AutomationId="PatchBenchSafeCopySourceStatus"
                                       Text="Installed game source: not set. Use Settings or browse a read-only BEA.exe source below."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <StackPanel Spacing="8">
                                <Button AutomationProperties.AutomationId="PatchBenchSafeCopyUseGameFolderButton"
                                        AutomationProperties.Name="Use configured game folder"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="40"
                                        Click="UseGameDirButton_Click">
                                    <TextBlock Text="Use configured game folder"
                                               TextAlignment="Center"
                                               TextWrapping="WrapWholeWords" />
                                </Button>
                                <Button AutomationProperties.AutomationId="PatchBenchSafeCopyBrowseSourceButton"
                                        AutomationProperties.Name="Browse BEA.exe source"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="40"
                                        Click="BrowseButton_Click">
                                    <TextBlock Text="Browse BEA.exe source"
                                               TextAlignment="Center"
                                               TextWrapping="WrapWholeWords" />
                                </Button>
                            </StackPanel>
                            <CheckBox x:Name="PatchBenchIncludeSavegamesOption"
                                      AutomationProperties.AutomationId="PatchBenchIncludeSavegamesOption"
                                      AutomationProperties.Name="Copy savegames into safe game copy"
                                      Content="Copy savegames into the safe copy"
                                      Checked="LaunchOptionCheckBox_Changed"
                                      Unchecked="LaunchOptionCheckBox_Changed" />
                            <TextBlock Text="Leave this off for clean patch tests. Turn it on when you want the safe copy to see your copied save folder. The source savegames folder is still read-only."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <TextBlock x:Name="PatchBenchSafeCopySelectionReadiness"
                                       AutomationProperties.AutomationId="PatchBenchSafeCopySelectionReadiness"
                                       AutomationProperties.Name="Safe copy selection readiness"
                                       AutomationProperties.LiveSetting="Polite"
                                       Text="Selection is valid. Choose a read-only BEA.exe source to create a safe game copy."

                                       TextWrapping="WrapWholeWords"
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <TextBlock x:Name="PatchBenchLabSelectionStatus"
                                       AutomationProperties.AutomationId="PatchBenchLabSelectionStatus"
                                       AutomationProperties.Name="Extra settings affecting the next copied profile"
                                       AutomationProperties.LiveSetting="Polite"
                                       Text="Extra settings for next copy: none active."
                                       TextWrapping="WrapWholeWords"
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <TextBlock Text="Online research files, post-create music staging or restore, and BEA.exe-only operations are reported separately; they do not affect Create."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <Button x:Name="PatchBenchPrepareCopiedProfileButton"
                                    AutomationProperties.AutomationId="PatchBenchPrepareCopiedProfileButton"
                                    AutomationProperties.Name="Create safe game copy"
                                    Content="Create safe copy"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="PrepareCopiedProfileButton_Click" />
                            <StackPanel x:Name="PatchBenchSafeCopyBusyPanel"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="Collapsed">
                                <ProgressRing x:Name="PatchBenchSafeCopyBusyRing"
                                              Width="20"
                                              Height="20"
                                              IsActive="False" />
                                <TextBlock x:Name="PatchBenchSafeCopyBusyStatus"
                                           AutomationProperties.AutomationId="PatchBenchSafeCopyBusyStatus"
                                           AutomationProperties.Name="Safe copy progress status"
                                           AutomationProperties.LiveSetting="Polite"
                                           Text="Safe copy operation in progress."
                                           VerticalAlignment="Center"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                            </StackPanel>
                            <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <TextBlock x:Name="PatchBenchCopiedProfileSummary"
                                           AutomationProperties.AutomationId="PatchBenchCopiedProfileSummary"
                                           AutomationProperties.Name="Safe game copy summary"
                                           Text="No safe game copy prepared in this session."
                                           TextWrapping="WrapWholeWords" />
                            </Border>
                            <Expander Header="Safe copy receipt"
                                      AutomationProperties.AutomationId="PatchBenchCopiedProfileReceiptExpander"
                                      AutomationProperties.Name="Safe copy receipt">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="PatchBenchCopiedProfileReceipt"
                                               AutomationProperties.AutomationId="PatchBenchCopiedProfileReceipt"
                                               AutomationProperties.Name="Safe copy receipt details"
                                               Text="Create a safe copy to see the exact profile, included changes, launch modifiers, savegame/music/control choices, and limits."
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Expander>
                            <StackPanel Spacing="10">
                                <Button x:Name="PatchBenchLaunchCopiedProfileButton"
                                        AutomationProperties.AutomationId="PatchBenchLaunchCopiedProfileButton"
                                        AutomationProperties.Name="Launch safe game copy"
                                        Content="Launch safe game copy"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="LaunchCopiedProfileButton_Click" />
                                <Button x:Name="PatchBenchStopCopiedProfileButton"
                                        AutomationProperties.AutomationId="PatchBenchStopCopiedProfileButton"
                                        AutomationProperties.Name="Stop copied game"
                                        Content="Stop copied game"
                                        Click="StopCopiedProfileButton_Click" />
                            </StackPanel>
                            <TextBlock Text="Launch starts the safe copy. Stop closes only the copied-game process started here and never deletes the safe copy. Save progress first; Stop may force-close the copied game if it does not respond."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Local split-screen"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <Button x:Name="PatchBenchLocalMultiplayerProbeButton"
                                            AutomationProperties.AutomationId="PatchBenchLocalMultiplayerProbeButton"
                                            AutomationProperties.Name="Set local split-screen test level for safe copy"
                                            Content="Local split-screen test"
                                            Click="LocalMultiplayerProbeButton_Click" />
                                    <TextBlock Text="Sets -level 850 for the safe copy. This targets the known local split-screen level range; it is not online multiplayer."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <TextBlock x:Name="PatchBenchCopiedProfileLaunchStatus"
                                           AutomationProperties.AutomationId="PatchBenchCopiedProfileLaunchStatus"
                                           AutomationProperties.Name="Safe game copy launch status"
                                           Text="No safe copy launch attempted. This does not confirm it reached the menu, stayed windowed, rendered correctly, or played replacement music."
                                           TextWrapping="WrapWholeWords" />
                            </Border>
                        </StackPanel>
                    </Border>


                </StackPanel>

                <Expander x:Name="PatchBenchLabExpander"
                          Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,16,0,0"
                          AutomationProperties.AutomationId="PatchBenchLabExpander"
                          AutomationProperties.Name="Open Lab recipes, experiments, and diagnostics"
                          Header="Lab: specialist recipes, experiments, and diagnostics"
                          IsExpanded="False">
                    <StackPanel Spacing="16"
                                Margin="0,12,0,0">
                        <TextBlock Text="Lab keeps specialist tools discoverable without presenting them as normal player recommendations. Each group has a different purpose and proof boundary."
                                   Style="{StaticResource SectionBodyTextStyle}" />
                        <Border Background="{ThemeResource ShellSurfaceBrush}"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8">
                            <TextBlock x:Name="PatchBenchProfileCatalogStatus"
                                       AutomationProperties.AutomationId="PatchBenchProfileCatalogStatus"
                                       AutomationProperties.Name="Profile catalog and preset source"
                                       Text="Profile catalog and preset source: tracked catalog status loads here."
                                       TextWrapping="WrapWholeWords" />
                        </Border>
                        <Expander x:Name="PatchBenchSelectedProfileDetailsExpander"
                                  AutomationProperties.AutomationId="PatchBenchSelectedProfileDetailsExpander"
                                  AutomationProperties.Name="Preset details and limits"
                                  Header="Preset details and limits">
                            <TextBlock x:Name="PatchBenchSelectedProfileDetails"
                                       AutomationProperties.AutomationId="PatchBenchSelectedProfileDetails"
                                       AutomationProperties.Name="Selected safe-copy preset details"
                                       Text="Selected safe-copy preset details: included changes, restore path, and limits update with the selected profile."
                                       TextWrapping="WrapWholeWords" />
                        </Expander>
                        <Expander x:Name="PatchBenchLabPatchExperimentsExpander"
                                  AutomationProperties.AutomationId="PatchBenchLabPatchExperimentsExpander"
                                  AutomationProperties.Name="Open Lab patch recipes and executable experiments"
                                  Header="Patch recipes and executable experiments"
                                  IsExpanded="False">
                            <StackPanel Spacing="16"
                                        Margin="0,12,0,0">
                                <TextBlock Text="Retained recipes and detailed patch rows are specialist choices, not normal player recommendations. Required compatibility rows remain automatically included."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                        <TextBlock Text="Legacy and research recipes"
                                                   AutomationProperties.HeadingLevel="Level2"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Background="{ThemeResource ShellMutedSurfaceBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Retained Lab recipes"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="These legacy and research presets remain available for receipts, regression work, and earlier instructions. They are not recommendations for normal play. The app still verifies every selected row before creating or launching the safe copy."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <TextBlock Text="Enhanced Profile Preview is a retained legacy recipe combining graphics flags, marker, margins, Goodies preview, and copied-options control starting values; it is not a general enhancement claim."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <TextBlock Text="Debug Camera Preview is an experimental research recipe selecting the camera toggle plus one Q-forward movement test."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <Border Background="{ThemeResource ShellSurfaceBrush}"
                                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Name="PatchBenchDebugCameraProofMatrixStatus"
                                                           AutomationProperties.AutomationId="PatchBenchDebugCameraProofMatrixStatus"
                                                           AutomationProperties.Name="Debug camera preview limits status"
                                                           Text="Debug Camera Preview keeps the other camera-key experiments manual so you can opt into them one at a time."
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="Use this preview as a small camera-control trial, not a full camera overhaul."
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="Some camera-key combinations still need broader menu and pause testing before they become presets."
                                                           TextWrapping="WrapWholeWords" />
