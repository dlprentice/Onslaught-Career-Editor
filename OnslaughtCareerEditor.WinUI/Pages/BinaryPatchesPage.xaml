<Page
    x:Class="OnslaughtCareerEditor.WinUI.Pages.BinaryPatchesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OnslaughtCareerEditor.WinUI.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="PatchBenchChoiceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource ShellSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="PatchBenchChoiceSelectedButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PatchBenchChoiceButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource ShellSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ShellAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="{ThemeResource ShellTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>
    <ScrollViewer AutomationProperties.AutomationId="PatchBenchScrollViewer"
                  AutomationProperties.Name="Windowed &amp; Mods workflow">
        <StackPanel Padding="20,18,20,24">
            <TextBlock Text="Windowed &amp; Mods"
                       AutomationProperties.AutomationId="BinaryPatchesPageTitle"
                       AutomationProperties.HeadingLevel="Level1"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Margin="0,6,0,14"
                       Text="A safe game copy is a separate folder this app creates from your installed game. Mods, patches, launch options, and music swaps happen there only. Your Steam install is never changed."
                       Style="{StaticResource SectionBodyTextStyle}" />
            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="What Gets Touched"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Steam/game install: read-only source. Used only to copy files; the installed game and original BEA.exe are not changed."
                                Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Safe game copy: app-owned folder. This is what Play runs."
                                Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock Text="Advanced BEA.exe-only copy: used for technical inspection and byte-level patching only. It is not a fully playable game folder."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>
            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Main workflow"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="1. Find your installed game. 2. Pick mods for a safe copy. 3. Create the safe copy. 4. Play the safe copy."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Grid ColumnSpacing="8"
                          RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PatchBenchTopUseGameFolderButton"
                                AutomationProperties.AutomationId="PatchBenchTopUseGameFolderButton"
                                AutomationProperties.Name="Use configured game folder for safe copy"
                                Content="Use configured folder"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Click="UseGameDirButton_Click" />
                        <Button x:Name="PatchBenchTopCreateSafeCopyButton"
                                AutomationProperties.AutomationId="PatchBenchTopCreateSafeCopyButton"
                                AutomationProperties.Name="Create safe game copy from main workflow"
                                Content="Create safe copy"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="PrepareCopiedProfileButton_Click" />
                        <Button x:Name="PatchBenchTopPlaySafeCopyButton"
                                AutomationProperties.AutomationId="PatchBenchTopPlaySafeCopyButton"
                                AutomationProperties.Name="Launch safe game copy from main workflow"
                                Content="Launch safe game copy"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Click="LaunchCopiedProfileButton_Click" />
                    </Grid>
                    <TextBlock Text="These shortcuts use the same guarded safe-copy workflow below; technical diagnostics stay hidden unless you choose to show them."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>
            <Border AutomationProperties.AutomationId="PatchBenchOnlinePrepCard"
                    BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="PatchBenchOnlinePrepTitle"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepTitle"
                               Text="Online multiplayer is not ready"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PatchBenchOnlinePrepSummary"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepSummary"
                               Text="Local split-screen launch preset is available for testing in a safe copy."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <TextBlock x:Name="PatchBenchOnlinePrepBoundary"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepBoundary"
                               Text="Online play is not available in this release. This preset only prepares a local split-screen safe-copy launch."
                               Style="{StaticResource SectionBodyTextStyle}" />
                    <Button x:Name="PatchBenchOnlinePrepLocalProbeButton"
                            AutomationProperties.AutomationId="PatchBenchOnlinePrepLocalProbeButton"
                            AutomationProperties.Name="Set up local split-screen test for safe copy"
                            Content="Use local split-screen launch preset"
                            HorizontalAlignment="Left"
                            Click="LocalMultiplayerProbeButton_Click" />
                    <TextBlock x:Name="PatchBenchOnlinePrepActionStatus"
                               AutomationProperties.AutomationId="PatchBenchOnlinePrepActionStatus"
                               Text="Select the local split-screen launch preset, then create and play a safe copy. This is not Host/Join."
                               Style="{StaticResource SectionBodyTextStyle}" />
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,16"
                  ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border x:Name="PatchSetBorder"
                        Grid.Column="0"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                        <StackPanel Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Choose game changes"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                  <TextBlock Text="Pick what the safe copy should include. Required compatibility fixes stay selected; optional changes can be added or cleared before you create the copy."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Available changes include windowed startup, wider display-mode support, graphics defaults, menu color presets, music swaps, Goodies preview, title marker, launch options, control-option presets, and experimental camera/control rows."
                                            Margin="0,6,0,0"
                                            Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Open Details and limits on a row when you want the technical checks and remaining limits."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Safe copy profiles"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Profiles are presets for normal play and testing. The app still verifies every selected row before creating or launching the safe copy."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Text="Enhanced Profile Preview combines the windowed setup, graphics defaults, PATCHED title marker, red menu background, Goodies preview, and copied-options control starting values."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Text="Debug Camera Preview selects the camera toggle plus one Q-forward movement test."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Border Background="{ThemeResource ShellSurfaceBrush}"
                                            BorderBrush="{ThemeResource ShellBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="PatchBenchDebugCameraProofMatrixStatus"
                                                       AutomationProperties.AutomationId="PatchBenchDebugCameraProofMatrixStatus"
                                                       AutomationProperties.Name="Debug camera preview limits status"
                                                       Text="Debug Camera Preview keeps the other camera-key experiments manual so you can opt into them one at a time."
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="Use this preview as a small camera-control trial, not a full camera overhaul."
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="Some camera-key combinations still need broader menu and pause testing before they become presets."
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="Experimental camera controls may be unstable. Open Details and limits on each row when you need exact test coverage."
                                                       Style="{StaticResource SectionBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="Fullscreen fallback, netcode, and in-game toggle menus are not part of any preset yet."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Text="Create safe copy records the selected rows in the safe-copy receipt and profile manifest. Control-options details are recorded only when an options manifest is written. Your installed game stays unchanged."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Border Background="{ThemeResource ShellSurfaceBrush}"
                                            BorderBrush="{ThemeResource ShellBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8">
                                        <TextBlock x:Name="PatchBenchSelectedProfileStatus"
                                                   AutomationProperties.AutomationId="PatchBenchSelectedProfileStatus"
                                                   AutomationProperties.Name="Selected safe-copy profile status"
                                                   Text="Selected profile: Compatibility Copy. This is the safest default."
                                                   TextWrapping="WrapWholeWords" />
                                    </Border>
                                    <Border Background="{ThemeResource ShellSurfaceBrush}"
                                            BorderBrush="{ThemeResource ShellBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8">
                                        <TextBlock x:Name="PatchBenchProfileCatalogStatus"
                                                   AutomationProperties.AutomationId="PatchBenchProfileCatalogStatus"
                                                   AutomationProperties.Name="Profile catalog and preset source"
                                                   Text="Profile catalog and preset source: tracked catalog status loads here."
                                                   TextWrapping="WrapWholeWords" />
                                    </Border>
                                    <Expander x:Name="PatchBenchSelectedProfileDetailsExpander"
                                              AutomationProperties.AutomationId="PatchBenchSelectedProfileDetailsExpander"
                                              AutomationProperties.Name="Preset details and limits"
                                              Header="Preset details and limits">
                                        <TextBlock x:Name="PatchBenchSelectedProfileDetails"
                                                   AutomationProperties.AutomationId="PatchBenchSelectedProfileDetails"
                                                   AutomationProperties.Name="Selected safe-copy preset details"
                                                   Text="Selected safe-copy preset details: included changes, restore path, and limits update with the selected profile."
                                                   TextWrapping="WrapWholeWords" />
                                    </Expander>
                                    <Grid ColumnSpacing="8"
                                          RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button x:Name="PatchBenchWindowedPresetButton"
                                                Content="Compatibility Copy"
                                                AutomationProperties.AutomationId="PatchBenchWindowedPresetButton"
                                                AutomationProperties.Name="Select Compatibility Copy profile"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="WindowedPresetButton_Click" />
                                        <Button x:Name="PatchBenchStableDefaultsButton"
                                                Content="Windowed + Graphics Defaults"
                                                AutomationProperties.AutomationId="PatchBenchStableDefaultsButton"
                                                AutomationProperties.Name="Select Windowed and Graphics Defaults profile"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="StableDefaultsButton_Click" />
                                        <Button x:Name="PatchBenchEnhancedPreviewProfileButton"
                                                Content="Enhanced Profile Preview"
                                                AutomationProperties.AutomationId="PatchBenchEnhancedPreviewProfileButton"
                                                AutomationProperties.Name="Select Enhanced Profile Preview profile"
                                                ToolTipService.ToolTip="Preview profile: compatibility, graphics defaults, PATCHED title marker, red menu background, Goodies preview, and copied-options control tweaks. Open row details for what was checked and current limits."
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="EnhancedPreviewPresetButton_Click" />
                                        <Button x:Name="PatchBenchClearSelectionButton"
                                                Content="Clear optional mods"
                                                AutomationProperties.AutomationId="PatchBenchClearSelectionButton"
                                                AutomationProperties.Name="Clear optional mod rows; safe copies still include required compatibility"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="ClearSelectionButton_Click" />
                                        <Button x:Name="PatchBenchModernGraphicsPresetButton"
                                                Content="Graphics flag rows only"
                                                AutomationProperties.AutomationId="PatchBenchModernGraphicsPresetButton"
                                                AutomationProperties.Name="Select extra graphics flag rows only"
                                                Grid.Row="2"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="ModernGraphicsPresetButton_Click" />
                                        <Button x:Name="PatchBenchDebugCameraPreviewProfileButton"
                                                Content="Debug Camera Preview"
                                                AutomationProperties.AutomationId="PatchBenchDebugCameraPreviewProfileButton"
                                                AutomationProperties.Name="Select Debug Camera Preview profile"
                                                AutomationProperties.HelpText="Experimental profile: Q-forward only; not full camera controls, joystick or analog camera coverage, pause/menu safety, or gameplay safety."
                                                ToolTipService.ToolTip="Experimental profile: compatibility plus free-camera toggle and one Q-forward movement path. It does not prove full camera controls or gameplay safety."
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="DebugCameraPreviewPresetButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Menu background color"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Choose one frontend clear-screen color for the safe copy. This affects the background and margins behind menu screens; it does not replace textures, fonts, or HUD colors."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Grid ColumnSpacing="8"
                                          RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button x:Name="PatchBenchMenuColorRedButton"
                                                Content="Red background"
                                                AutomationProperties.AutomationId="PatchBenchMenuColorRedButton"
                                                AutomationProperties.Name="Select red menu background color"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="MenuColorRedButton_Click" />
                                        <Button x:Name="PatchBenchMenuColorGreenButton"
                                                Content="Green background"
                                                AutomationProperties.AutomationId="PatchBenchMenuColorGreenButton"
                                                AutomationProperties.Name="Select green menu background color"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="MenuColorGreenButton_Click" />
                                        <Button x:Name="PatchBenchMenuColorBlackButton"
                                                Content="Black background"
                                                AutomationProperties.AutomationId="PatchBenchMenuColorBlackButton"
                                                AutomationProperties.Name="Select black menu background color"
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="MenuColorBlackButton_Click" />
                                        <Button x:Name="PatchBenchMenuColorClearButton"
                                                Content="Clear menu color"
                                                AutomationProperties.AutomationId="PatchBenchMenuColorClearButton"
                                                AutomationProperties.Name="Clear menu background color selection"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                                Click="MenuColorClearButton_Click" />
                                    </Grid>
                                    <TextBlock x:Name="PatchBenchMenuColorSelectionStatus"
                                               AutomationProperties.AutomationId="PatchBenchMenuColorSelectionStatus"
                                               AutomationProperties.Name="Selected menu background color status"
                                               Text="Selected menu background: none."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Background="{ThemeResource ShellMutedSurfaceBrush}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Title marker and Goodies preview"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="PATCHED marker shows the word PATCHED on the title screen so you can tell a modded copy apart. Goodies preview shows Goodies as unlocked in the gallery view of the safe copy; it does not change your save."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <Grid ColumnSpacing="8"
                                          RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Content="Add PATCHED marker"
                                                AutomationProperties.AutomationId="PatchBenchAddVersionMarkerButton"
                                                AutomationProperties.Name="Add PATCHED title marker row"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Click="AddVersionMarkerButton_Click" />
                                        <Button Content="Clear PATCHED marker"
                                                AutomationProperties.AutomationId="PatchBenchClearVersionMarkerButton"
                                                AutomationProperties.Name="Clear PATCHED title marker row"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Click="ClearVersionMarkerButton_Click" />
                                        <Button Content="Add Goodies preview"
                                                AutomationProperties.AutomationId="PatchBenchAddGoodiesPreviewButton"
                                                AutomationProperties.Name="Add Goodies display preview row"
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Click="AddGoodiesPreviewButton_Click" />
                                        <Button Content="Clear Goodies preview"
                                                AutomationProperties.AutomationId="PatchBenchClearGoodiesPreviewButton"
                                                AutomationProperties.Name="Clear Goodies display preview row"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Click="ClearGoodiesPreviewButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="PatchGroupsItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:BinaryPatchGroupModel">
                                        <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,12">
                                            <StackPanel Spacing="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource SectionBodyTextStyle}" />
                                                    <TextBlock Text="{Binding ScanSummary}"
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource SectionBodyTextStyle}" />
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:BinaryPatchItemModel">
                                                            <StackPanel Spacing="4"
                                                                        AutomationProperties.AutomationId="{Binding RowAutomationId}"
                                                                        Margin="0,0,0,10">
                                                                <CheckBox Checked="PatchCheckBox_Changed"
                                                                          AutomationProperties.AutomationId="{Binding CheckBoxAutomationId}"
                                                                          AutomationProperties.Name="{Binding DisplayName}"
                                                                          AutomationProperties.HelpText="{Binding AccessibilityHelpText}"
                                                                          Unchecked="PatchCheckBox_Changed"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          HorizontalAlignment="Stretch"
                                                                          HorizontalContentAlignment="Stretch"
                                                                          Padding="2,2,0,2"
                                                                          Margin="0">
                                                                    <StackPanel Spacing="4"
                                                                                Margin="10,0,0,0">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Text="{Binding Summary}"
                                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                                        <TextBlock Text="{Binding UserFacingStatus}"
                                                                                   FontSize="12"
                                                                                   TextWrapping="WrapWholeWords"
                                                                                   Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                        <TextBlock Text="{Binding TrackLabel}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{Binding TrackBrush}"
                                                                                   CharacterSpacing="60"
                                                                                   Opacity="0.95" />
                                                                    </StackPanel>
                                                                </CheckBox>
                                                                <Expander Header="{Binding DetailsHeader}"
                                                                          AutomationProperties.AutomationId="{Binding DetailsAutomationId}"
                                                                          AutomationProperties.Name="{Binding DetailsHeader}"
                                                                          Margin="36,0,0,0">
                                                                    <StackPanel Spacing="8">
                                                                            <StackPanel Spacing="2">
                                                                                <TextBlock Text="What should change"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding ExpectedVisibleResult}"
                                                                                           FontSize="12"
                                                                                           TextWrapping="WrapWholeWords"
                                                                                           Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                            </StackPanel>
                                                                            <StackPanel Spacing="2">
                                                                                <TextBlock Text="What was checked"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding VerifiedProof}"
                                                                                           FontSize="12"
                                                                                           TextWrapping="WrapWholeWords"
                                                                                           Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                            </StackPanel>
                                                                            <StackPanel Spacing="2">
                                                                                <TextBlock Text="Not proven yet"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding StillUnproven}"
                                                                                           FontSize="12"
                                                                                           TextWrapping="WrapWholeWords"
                                                                                           Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                            </StackPanel>
                                                                            <StackPanel Spacing="2">
                                                                                <TextBlock Text="Proof note"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding ProofReference}"
                                                                                           FontSize="12"
                                                                                           TextWrapping="WrapWholeWords"
                                                                                           Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                            </StackPanel>
                                                                             <TextBlock Text="{Binding OffsetText}"
                                                                                        FontSize="12"
                                                                                        Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                            <TextBlock Text="{Binding Spec.Key}"
                                                                                       FontSize="12"
                                                                                       Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                    </StackPanel>
                                                                </Expander>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1"
                            Spacing="16">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Safe game copy"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Create a launchable app-owned game copy. You do not need the advanced BEA.exe-only copy first. This always adds the required windowed compatibility patches; selected mods are added too. Savegames are optional, and the Steam/game install is unchanged."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <TextBlock x:Name="PatchBenchSafeCopySourceStatus"
                                       AutomationProperties.AutomationId="PatchBenchSafeCopySourceStatus"
                                       Text="Installed game source: not set. Use Settings or browse a read-only BEA.exe source below."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <StackPanel Spacing="8">
                                <Button AutomationProperties.AutomationId="PatchBenchSafeCopyUseGameFolderButton"
                                        AutomationProperties.Name="Use configured game folder"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="40"
                                        Click="UseGameDirButton_Click">
                                    <TextBlock Text="Use configured game folder"
                                               TextAlignment="Center"
                                               TextWrapping="WrapWholeWords" />
                                </Button>
