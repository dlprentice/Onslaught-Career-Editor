                                <TextBlock Text="Invert options write P1/P2 look flags in the copied defaultoptions.bea only. They are not executable patches and do not prove improved runtime feel."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Control diagnostics"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <Grid ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="PatchBenchControlBaselinePresetButton"
                                            AutomationProperties.AutomationId="PatchBenchControlBaselinePresetButton"
                                            AutomationProperties.Name="Set control diagnostics baseline config 1"
                                            Content="Baseline config 1"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                            Click="ControlBaselinePresetButton_Click" />
                                    <Button x:Name="PatchBenchControlSharpenedPresetButton"
                                            AutomationProperties.AutomationId="PatchBenchControlSharpenedPresetButton"
                                            AutomationProperties.Name="Set control diagnostics sensitivity test config 1"
                                            Content="Sensitivity test config 1"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                            Click="ControlSharpenedPresetButton_Click" />
                                    <Button x:Name="PatchBenchControlConfig2PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchControlConfig2PresetButton"
                                            AutomationProperties.Name="Set control diagnostics swapped sticks config 2"
                                            Content="Swapped config 2"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                            Click="ControlConfig2PresetButton_Click" />
                                    <Button x:Name="PatchBenchControlConfig3PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchControlConfig3PresetButton"
                                            AutomationProperties.Name="Set control diagnostics alternate morph jets config 3"
                                            Content="Alt morph/jets config 3"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                            Click="ControlConfig3PresetButton_Click" />
                                    <Button x:Name="PatchBenchControlConfig4PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchControlConfig4PresetButton"
                                            AutomationProperties.Name="Set control diagnostics swapped alternate config 4"
                                            Content="Swapped alt config 4"
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PatchBenchChoiceButtonStyle}"
                                            Click="ControlConfig4PresetButton_Click" />
                                </Grid>
                                <TextBlock Text="These are A/B test presets for safe-copy control diagnostics. They do not add deadzone, look-curve, camera, movement, or online patches."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Optional texture RAM limit"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBox x:Name="PatchBenchTextureRamLimitLaunchOption"
                                         AutomationProperties.AutomationId="PatchBenchTextureRamLimitLaunchOption"
                                          AutomationProperties.Name="Optional texture RAM limit in megabytes for safe copy"
                                         TextChanged="LaunchOptionTextBox_TextChanged"
                                         PlaceholderText="Leave blank, or enter MB from 8 to 512" />
                                </StackPanel>
                            </Expander>
                            <StackPanel Spacing="10">
                                <TextBlock Text="Swap music in safe copy"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Swap one copied music track with another, or stage an external replacement OGG inside the safe copy. The original install is unchanged."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Quick copied-track swap"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBlock Text="Named presets use shipped copied tracks only and write a restore manifest in the safe copy."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <Border Background="{ThemeResource ShellSurfaceBrush}"
                                        BorderBrush="{ThemeResource ShellBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="PatchBenchMusicAudibleProofContractStatus"
                                                   AutomationProperties.AutomationId="PatchBenchMusicAudibleProofContractStatus"
                                                   AutomationProperties.Name="Music swap status"
                                                   Text="A music swap modifies safe-copy files only. Audible proof still requires a bounded audio-output capture. Staging and CDB decode are not audible playback proof."
                                                   Style="{StaticResource SectionBodyTextStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Use Restore if you want to undo the staged track swap before testing."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Grid ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="PatchBenchMusicSwapBea02ForBea01PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchMusicSwapBea02ForBea01PresetButton"
                                            AutomationProperties.Name="Stage BEA_02 over BEA_01 in safe copy"
                                            Content="BEA_02 over BEA_01"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Click="MusicSwapBea02ForBea01PresetButton_Click" />
                                    <Button x:Name="PatchBenchMusicSwapBea01ForBea02PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchMusicSwapBea01ForBea02PresetButton"
                                            AutomationProperties.Name="Stage BEA_01 over BEA_02 in safe copy"
                                            Content="BEA_01 over BEA_02"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Click="MusicSwapBea01ForBea02PresetButton_Click" />
                                    <Button x:Name="PatchBenchMusicSwapBea02ForBea04PresetButton"
                                            AutomationProperties.AutomationId="PatchBenchMusicSwapBea02ForBea04PresetButton"
                                            AutomationProperties.Name="Stage BEA_02 over BEA_04 in safe copy"
                                            Content="BEA_02 over BEA_04"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Click="MusicSwapBea02ForBea04PresetButton_Click" />
                                </Grid>
                                <ComboBox x:Name="PatchBenchMusicTargetTrackComboBox"
                                          AutomationProperties.AutomationId="PatchBenchMusicTargetTrackComboBox"
                                          AutomationProperties.Name="Safe-copy target music track"
                                          Header="Replace this copied track"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="MusicTrackComboBox_SelectionChanged" />
                                <ComboBox x:Name="PatchBenchMusicReplacementTrackComboBox"
                                          AutomationProperties.AutomationId="PatchBenchMusicReplacementTrackComboBox"
                                          AutomationProperties.Name="Safe-copy replacement music track"
                                          Header="With this copied track"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="MusicTrackComboBox_SelectionChanged" />
                                <Button x:Name="PatchBenchStageCopiedTrackSwapButton"
                                        AutomationProperties.AutomationId="PatchBenchStageCopiedTrackSwapButton"
                                        AutomationProperties.Name="Swap safe-copy music tracks"
                                        Content="Swap safe-copy tracks"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="StageCopiedTrackSwapButton_Click" />
                                <TextBlock Text="Advanced replacement target"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBox x:Name="PatchBenchMusicTargetFileName"
                                         AutomationProperties.AutomationId="PatchBenchMusicTargetFileName"
                                         AutomationProperties.Name="Target track in safe copy"
                                         TextChanged="MusicReplacementInput_TextChanged"
                                         PlaceholderText="Existing copied data\Music file, for example BEA_01(Master).ogg" />
                                <TextBlock Text="Replacement track (.ogg)"
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <TextBox x:Name="PatchBenchMusicReplacementPath"
                                         AutomationProperties.AutomationId="PatchBenchMusicReplacementPath"
                                         AutomationProperties.Name="Replacement track OGG path"
                                         TextChanged="MusicReplacementInput_TextChanged"
                                         PlaceholderText="Path to replacement .ogg" />
                                <TextBlock Text="Target must be an existing file in the safe copy's data\Music folder. Stop the safe copy before staging or restoring."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                                <StackPanel Spacing="10">
                                    <Button x:Name="PatchBenchStageMusicReplacementButton"
                                            AutomationProperties.AutomationId="PatchBenchStageMusicReplacementButton"
                                            AutomationProperties.Name="Stage music replacement in safe copy"
                                            Content="Stage track in safe copy"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="StageMusicReplacementButton_Click" />
                                    <Button x:Name="PatchBenchRestoreMusicReplacementButton"
                                            AutomationProperties.AutomationId="PatchBenchRestoreMusicReplacementButton"
                                            AutomationProperties.Name="Restore safe-copy music backup"
                                            Content="Restore safe-copy track backup"
                                            Click="RestoreMusicReplacementButton_Click" />
                                </StackPanel>
                                <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                        BorderBrush="{ThemeResource ShellBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,10">
                                            <TextBlock x:Name="PatchBenchMusicReplacementStatus"
                                               AutomationProperties.AutomationId="PatchBenchMusicReplacementStatus"
                                               AutomationProperties.Name="Safe-copy music replacement status"
                                                Text="No music swap staged. Staging only; in-game playback is still experimental and unproven."
                                               TextWrapping="WrapWholeWords" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Expander Header="Advanced technical check, not needed to play"
                              AutomationProperties.AutomationId="PatchBenchAdvancedTechnicalExpander"
                              AutomationProperties.Name="Advanced technical check, not needed to play">
                        <StackPanel Spacing="16">
                            <TextBlock Text="This patches one copied executable for inspection only. Use Create safe copy to play."
                                       Style="{StaticResource SectionBodyTextStyle}" />
                            <Border Style="{StaticResource SectionCardStyle}"
                                    Margin="0">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Advanced: patch one BEA.exe copy"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Advanced copy source"
                                                   FontWeight="SemiBold" />
                                        <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10">
                                            <TextBlock x:Name="SourceExeSummaryTextBlock"
                                                       Text="Select BEA.exe or BEA.exe.original.backup as read-only source"
                                                       TextWrapping="WrapWholeWords" />
                                        </Border>
                                        <Expander Header="Source path details">
                                            <TextBox x:Name="SourceExePathTextBox"
                                                     AutomationProperties.AutomationId="PatchBenchSourceExePath"
                                                     AutomationProperties.Name="Source executable path"
                                                     TextChanged="SourceExePathTextBox_TextChanged"
                                                     PlaceholderText="Select BEA.exe or BEA.exe.original.backup as read-only source" />
                                        </Expander>
                                    </StackPanel>
                                    <StackPanel Spacing="8">
                                        <Button AutomationProperties.AutomationId="PatchBenchBrowseSourceButton"
                                                AutomationProperties.Name="Browse read-only BEA.exe source"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinHeight="40"
                                                Click="BrowseButton_Click">
                                            <TextBlock Text="Browse read-only BEA.exe source"
                                                       TextAlignment="Center"
                                                       TextWrapping="WrapWholeWords" />
                                        </Button>
                                        <Button AutomationProperties.AutomationId="PatchBenchUseGameFolderButton"
                                                AutomationProperties.Name="Use configured source game folder"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                MinHeight="40"
                                                Click="UseGameDirButton_Click">
                                            <TextBlock Text="Use configured source game folder"
                                                       TextAlignment="Center"
                                                       TextWrapping="WrapWholeWords" />
                                        </Button>
                                    </StackPanel>
                                    <Button x:Name="CreateWorkingCopyButton"
                                            AutomationProperties.AutomationId="PatchBenchCreateWorkingCopyButton"
                                            Content="Create BEA.exe-only copy"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="CreateWorkingCopyButton_Click" />
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="BEA.exe-only copy"
                                                   FontWeight="SemiBold" />
                                        <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10">
                                            <TextBlock x:Name="WorkingCopySummaryTextBlock"
                                                       Text="Create a copy before verifying or applying patches"
                                                       TextWrapping="WrapWholeWords" />
                                        </Border>
                                        <Expander Header="BEA.exe-only copy details">
                                            <TextBox x:Name="ExePathTextBox"
                                                     AutomationProperties.AutomationId="PatchBenchWorkingCopyPath"
                                                     AutomationProperties.Name="BEA.exe-only copy executable path"
                                                     IsReadOnly="True"
                                                     TextChanged="ExePathTextBox_TextChanged"
                                                     PlaceholderText="Create a copy before verifying or applying patches" />
                                        </Expander>
                                    </StackPanel>
                                    <TextBlock x:Name="SelectionSummaryTextBlock"
                                               Text="No patches selected."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Text="Advanced BEA.exe-only copies are for byte inspection and apply/restore checks. Restore or create a fresh copy before changing patch sets; this is not the normal launch path."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    Margin="0">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Advanced copy actions"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Button x:Name="VerifyButton"
                                            AutomationProperties.AutomationId="PatchBenchVerifyButton"
                                            Content="Verify BEA.exe-only copy"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="VerifyButton_Click" />
                                    <Button x:Name="ApplyButton"
                                            AutomationProperties.AutomationId="PatchBenchApplyButton"
                                            Content="Apply to BEA.exe-only copy"
                                            Click="ApplyButton_Click" />
                                    <Button x:Name="RestoreButton"
                                            AutomationProperties.AutomationId="PatchBenchRestoreButton"
                                            Content="Restore copied BEA.exe backup"
                                            Click="RestoreButton_Click" />
                                    <TextBlock x:Name="WorkflowHintTextBlock"
                                               AutomationProperties.AutomationId="PatchBenchWorkflowHint"
                                               Text="Create a BEA.exe-only copy before verification or patching."
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </Grid>

            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Last operation"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="OperationLogTextBox"
                             AutomationProperties.AutomationId="PatchBenchOperationLog"
                             AutomationProperties.Name="Last operation log"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             MinHeight="180"
                             MaxHeight="260"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
