                                                                                <StackPanel Spacing="2">
                                                                                    <TextBlock Text="What should change"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold" />
                                                                                    <TextBlock Text="{Binding ExpectedVisibleResult}"
                                                                                               FontSize="12"
                                                                                               TextWrapping="WrapWholeWords"
                                                                                               Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                                </StackPanel>
                                                                                <StackPanel Spacing="2">
                                                                                    <TextBlock Text="What was checked"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold" />
                                                                                    <TextBlock Text="{Binding VerifiedProof}"
                                                                                               FontSize="12"
                                                                                               TextWrapping="WrapWholeWords"
                                                                                               Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                                </StackPanel>
                                                                                <StackPanel Spacing="2">
                                                                                    <TextBlock Text="Not proven yet"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold" />
                                                                                    <TextBlock Text="{Binding StillUnproven}"
                                                                                               FontSize="12"
                                                                                               TextWrapping="WrapWholeWords"
                                                                                               Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                                </StackPanel>
                                                                                <StackPanel Spacing="2">
                                                                                    <TextBlock Text="Proof note"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold" />
                                                                                    <TextBlock Text="{Binding ProofReference}"
                                                                                               FontSize="12"
                                                                                               TextWrapping="WrapWholeWords"
                                                                                               Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                                </StackPanel>
                                                                                 <TextBlock Text="{Binding OffsetText}"
                                                                                            FontSize="12"
                                                                                            Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                                <TextBlock Text="{Binding Spec.Key}"
                                                                                           FontSize="12"
                                                                                           Foreground="{StaticResource ShellMutedTextBrush}" />
                                                                        </StackPanel>
                                                                    </Expander>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </StackPanel>
