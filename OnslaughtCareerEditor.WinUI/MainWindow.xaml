<Window
    x:Class="OnslaughtCareerEditor.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Onslaught Toolkit - Battle Engine Aquila">
    <Grid Background="{ThemeResource ShellPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource ShellHeroBrush}"
                Padding="22,16">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Onslaught Toolkit"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{ThemeResource ShellHeroTextBrush}" />
                    <TextBlock Text="Retail save editing, global configuration patching, byte-verified executable fixes, and curated preservation notes."
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{ThemeResource ShellHeroTextBrush}"
                               Opacity="0.85"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button x:Name="LaunchGameButton"
                        Grid.Column="1"
                        Content="Launch Game"
                        Click="LaunchGameButton_Click"
                        VerticalAlignment="Center"
                        Style="{StaticResource HeroActionButtonStyle}" />
            </Grid>
        </Border>

        <NavigationView Grid.Row="1"
                        x:Name="ShellNavigationView"
                        AutomationProperties.Name="Main navigation tabs"
                        Background="Transparent"
                        AlwaysShowHeader="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Top"
                        SelectionChanged="ShellNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="SavesNavigationItem" Content="Saves" Tag="saves" />
                <NavigationViewItem x:Name="MediaNavigationItem" Content="Media" Tag="media" />
                <NavigationViewItem x:Name="LoreNavigationItem" Content="Lore" Tag="lore" />
                <NavigationViewItem x:Name="BinaryNavigationItem" Content="Binary Patches" Tag="binary" />
                <NavigationViewItem x:Name="SettingsNavigationItem" Content="Settings" Tag="settings" />
                <NavigationViewItem x:Name="AboutNavigationItem" Content="About" Tag="about" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Border Grid.Row="2"
                Background="{ThemeResource ShellStatusBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ShellTextBrush}"
                           Text="Ready" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10">
                    <TextBlock Text="Game"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource ShellMutedTextBrush}" />
                    <TextBlock x:Name="GameDirectoryTextBlock"
                               MaxWidth="420"
                               FontSize="12"
                               Foreground="{ThemeResource ShellTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
