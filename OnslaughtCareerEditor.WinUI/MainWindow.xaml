<Window
    x:Class="OnslaughtCareerEditor.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Onslaught Toolkit - Battle Engine Aquila">
    <Grid Background="{ThemeResource ShellPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource ShellHeroBrush}"
                Padding="22,16">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Onslaught Toolkit"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{ThemeResource ShellHeroTextBrush}" />
                    <TextBlock Text="Your toolkit for safe save editing, game settings, media, lore, and copied-game mods."
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{ThemeResource ShellHeroTextBrush}"
                               Opacity="0.85"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button x:Name="ReviewSetupButton"
                        Grid.Column="1"
                        AutomationProperties.AutomationId="ReviewSetupButton"
                        AccessKey="R"
                        Content="Review Setup"
                        Click="ReviewSetupButton_Click"
                        VerticalAlignment="Center"
                        Style="{StaticResource HeroActionButtonStyle}" />
            </Grid>
        </Border>

        <NavigationView Grid.Row="1"
                        x:Name="ShellNavigationView"
                        AutomationProperties.Name="Main navigation tabs"
                        Background="Transparent"
                        AlwaysShowHeader="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Top"
                        SelectionChanged="ShellNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeNavigationItem"
                                    AutomationProperties.AutomationId="HomeNavigationItem"
                                    AccessKey="H"
                                    Content="Home"
                                    Tag="home" />
                <NavigationViewItem x:Name="SavesNavigationItem"
                                    AutomationProperties.AutomationId="SavesNavigationItem"
                                    AccessKey="S"
                                    Content="Save Lab"
                                    Tag="saves" />
                <NavigationViewItem x:Name="MediaNavigationItem"
                                    AutomationProperties.AutomationId="MediaNavigationItem"
                                    AccessKey="M"
                                    Content="Media"
                                    Tag="media" />
                <NavigationViewItem x:Name="AssetLibraryNavigationItem"
                                    AutomationProperties.AutomationId="AssetLibraryNavigationItem"
                                    AccessKey="A"
                                    Content="Asset Library"
                                    Tag="assets" />
                <NavigationViewItem x:Name="LoreNavigationItem"
                                    AutomationProperties.AutomationId="LoreNavigationItem"
                                    AccessKey="L"
                                    Content="Lore"
                                    Tag="lore" />
                <NavigationViewItem x:Name="BinaryNavigationItem"
                                    AutomationProperties.AutomationId="BinaryNavigationItem"
                                    AccessKey="W"
                                    Content="Windowed &amp; Mods"
                                    Tag="binary" />
                <NavigationViewItem x:Name="SettingsNavigationItem"
                                    AutomationProperties.AutomationId="SettingsNavigationItem"
                                    AccessKey="T"
                                    Content="Settings"
                                    Tag="settings" />
                <NavigationViewItem x:Name="AboutNavigationItem"
                                    AutomationProperties.AutomationId="AboutNavigationItem"
                                    AccessKey="B"
                                    Content="About"
                                    Tag="about" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Border Grid.Row="2"
                Background="{ThemeResource ShellStatusBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="0"
                           AutomationProperties.Name="Application status"
                           AutomationProperties.LiveSetting="Polite"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ShellTextBrush}"
                           Text="Ready" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10">
                    <TextBlock Text="Game"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource ShellMutedTextBrush}" />
                    <TextBlock x:Name="GameDirectoryTextBlock"
                               MaxWidth="420"
                               FontSize="12"
                               Foreground="{ThemeResource ShellTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
