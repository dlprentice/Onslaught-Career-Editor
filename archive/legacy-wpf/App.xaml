<Application x:Class="Onslaught___Career_Editor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Indigo" SecondaryColor="Blue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════════════════════════
                 Semantic color aliases
                 ═══════════════════════════════════════════════════════════════ -->
            <SolidColorBrush x:Key="PageBackgroundBrush"    Color="#FAFAFA" />
            <SolidColorBrush x:Key="SurfaceBrush"           Color="#FFFFFF" />
            <SolidColorBrush x:Key="SurfaceMutedBrush"      Color="#F5F5F5" />
            <SolidColorBrush x:Key="SurfaceAccentBrush"     Color="#E8EAF6" />
            <SolidColorBrush x:Key="SurfaceStrongBrush"     Color="#C5CAE9" />
            <SolidColorBrush x:Key="PrimaryTextBrush"       Color="#212121" />
            <SolidColorBrush x:Key="MutedTextBrush"         Color="#757575" />
            <SolidColorBrush x:Key="AccentBrush"            Color="#3F51B5" />
            <SolidColorBrush x:Key="AccentDarkBrush"        Color="#283593" />
            <SolidColorBrush x:Key="WarmAccentBrush"        Color="#E65100" />
            <SolidColorBrush x:Key="SuccessBrush"           Color="#2E7D32" />
            <SolidColorBrush x:Key="DangerBrush"            Color="#C62828" />
            <SolidColorBrush x:Key="CardBorderBrush"        Color="#E0E0E0" />
            <SolidColorBrush x:Key="CardBorderStrongBrush"  Color="#BDBDBD" />

            <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#283593" Offset="0" />
                <GradientStop Color="#1A237E" Offset="1" />
            </LinearGradientBrush>

            <!-- ═══════════════════════════════════════════════════════════════
                 Window
                 ═══════════════════════════════════════════════════════════════ -->
            <Style TargetType="Window" BasedOn="{StaticResource MaterialDesignWindow}">
                <Setter Property="Background"  Value="{StaticResource PageBackgroundBrush}" />
                <Setter Property="Foreground"  Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="UseLayoutRounding"     Value="True" />
                <Setter Property="SnapsToDevicePixels"   Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Typography
                 ═══════════════════════════════════════════════════════════════ -->
            <Style x:Key="HelperTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground"   Value="{StaticResource MutedTextBrush}" />
                <Setter Property="FontSize"     Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CalloutTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
                <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize"   Value="14" />
                <Setter Property="Margin"     Value="0,0,0,4" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Cards / callouts
                 ═══════════════════════════════════════════════════════════════ -->
            <Style x:Key="InfoCalloutBorderStyle" TargetType="Border">
                <Setter Property="Background"      Value="#E8EAF6" />
                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="Padding"         Value="12,10" />
                <Setter Property="Margin"          Value="0,0,0,10" />
            </Style>

            <Style x:Key="WarningCalloutBorderStyle" TargetType="Border" BasedOn="{StaticResource InfoCalloutBorderStyle}">
                <Setter Property="Background"  Value="#FFF3E0" />
                <Setter Property="BorderBrush" Value="#FFB74D" />
            </Style>

            <Style x:Key="InsetCardBorderStyle" TargetType="Border">
                <Setter Property="Background"      Value="{StaticResource SurfaceMutedBrush}" />
                <Setter Property="BorderBrush"     Value="{StaticResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="Padding"         Value="14" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Focus visual
                 ═══════════════════════════════════════════════════════════════ -->
            <Style x:Key="AccessibleFocusVisualStyle" TargetType="Control">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Control">
                            <Rectangle Margin="2"
                                       Stroke="{StaticResource AccentDarkBrush}"
                                       StrokeThickness="2"
                                       StrokeDashArray="2,1"
                                       SnapsToDevicePixels="True" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 GroupBox helpers
                 ═══════════════════════════════════════════════════════════════ -->
            <Style x:Key="SectionGroupBoxStyle" TargetType="GroupBox">
                <Setter Property="Margin"  Value="0,0,0,12" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="ActionBarGridStyle" TargetType="FrameworkElement">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="OutputGroupBoxStyle" TargetType="GroupBox" BasedOn="{StaticResource SectionGroupBoxStyle}">
                <Setter Property="Margin" Value="0,6,0,0" />
            </Style>

            <Style x:Key="OutputTextBoxStyle" TargetType="TextBox">
                <Setter Property="Padding"        Value="8,6" />
                <Setter Property="TextWrapping"    Value="Wrap" />
                <Setter Property="FontFamily"      Value="Consolas" />
                <Setter Property="FontSize"        Value="11" />
                <Setter Property="IsReadOnly"      Value="True" />
                <Setter Property="Foreground"      Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Background"      Value="{StaticResource SurfaceMutedBrush}" />
                <Setter Property="BorderBrush"     Value="{StaticResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight"       Value="30" />
                <Setter Property="MaxHeight"       Value="56" />
                <Setter Property="VerticalScrollBarVisibility"   Value="Auto" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Buttons — Material Design based
                 ═══════════════════════════════════════════════════════════════ -->
            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}" />

            <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"  Value="{StaticResource SuccessBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                <Setter Property="Foreground"  Value="White" />
            </Style>

            <Style x:Key="WarmButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"  Value="{StaticResource WarmAccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource WarmAccentBrush}" />
                <Setter Property="Foreground"  Value="White" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Input controls
                 ═══════════════════════════════════════════════════════════════ -->
            <Style TargetType="TextBox">
                <Setter Property="Foreground"  Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="CaretBrush"  Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Background"  Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                <Setter Property="Padding"     Value="8,6" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Foreground"  Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Background"  Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Padding"     Value="6,4" />
                <Setter Property="MinHeight"   Value="32" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Margin"     Value="0,2,0,2" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Navigation tabs — Material Design underline style
                 ═══════════════════════════════════════════════════════════════ -->
            <Style TargetType="TabControl">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="BorderThickness"  Value="0" />
                <Setter Property="Padding"          Value="0" />
            </Style>

            <Style x:Key="PrimaryTabItemStyle" TargetType="TabItem">
                <Setter Property="Padding"    Value="18,10" />
                <Setter Property="MinHeight"  Value="40" />
                <Setter Property="MinWidth"   Value="96" />
                <Setter Property="Margin"     Value="0,0,4,0" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent">
                                <TextBlock x:Name="HeaderText"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAccentBrush}" />
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAccentBrush}" />
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryTabItemStyle" TargetType="TabItem">
                <Setter Property="Padding"    Value="14,8" />
                <Setter Property="MinHeight"  Value="36" />
                <Setter Property="MinWidth"   Value="80" />
                <Setter Property="Margin"     Value="0,0,4,0" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True"
                                    BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent">
                                <TextBlock x:Name="HeaderText"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAccentBrush}" />
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAccentBrush}" />
                                    <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════════
                 Remaining controls
                 ═══════════════════════════════════════════════════════════════ -->
            <Style TargetType="TreeView">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="BorderThickness"  Value="0" />
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="CanUserAddRows"    Value="False" />
                <Setter Property="CanUserDeleteRows" Value="False" />
            </Style>

            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroupBoxStyle}" />

            <Style TargetType="Expander">
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="AdvancedSectionExpanderStyle" TargetType="Expander" BasedOn="{StaticResource {x:Type Expander}}">
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style TargetType="Menu">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="FontSize"   Value="13" />
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Padding"  Value="8,4" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
