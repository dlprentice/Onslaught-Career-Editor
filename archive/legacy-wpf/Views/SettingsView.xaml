<UserControl x:Class="Onslaught___Career_Editor.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource InfoCalloutBorderStyle}">
                    <TextBlock Style="{StaticResource CalloutTextStyle}">
                        Changes in this tab save immediately. Use it to point the app at your Battle Engine Aquila install and to set media behavior defaults.
                    </TextBlock>
                </Border>

                <!-- Game Directory -->
                <GroupBox Header="Game Directory" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{StaticResource MutedTextBrush}">
                            Set the path to your Battle Engine Aquila installation. This is used by the save editors, Binary Patches, and media tabs to locate the retail files they operate on.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GameDirTextBox"
                                     Grid.Column="0"
                                     TabIndex="0"
                                     AutomationProperties.Name="Game directory path"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    TabIndex="1"
                                    AutomationProperties.Name="Browse for game directory"
                                    Click="BrowseGameDir_Click"
                                    Padding="15,5"
                                    Margin="0,0,5,0"
                                    ToolTip="Browse for game installation directory"/>
                            <Button Grid.Column="2"
                                    Content="Auto-Detect"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    TabIndex="2"
                                    AutomationProperties.Name="Auto-detect game directory"
                                    Click="AutoDetectGameDir_Click"
                                    Padding="15,5"
                                    ToolTip="Automatically find game installation via Steam or common paths"/>
                        </Grid>
                        <TextBlock x:Name="GameDirStatus"
                                   Margin="0,8,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Save Files Directory -->
                <GroupBox Header="Save Files" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{StaticResource MutedTextBrush}">
                            Save files are typically located in the game's save directory. The editor will scan this location for .bes and .bea files (including defaultoptions.bea in the Steam build).
                        </TextBlock>
                        <TextBlock x:Name="SaveDirLabel" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SaveFileCount" Margin="0,5,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Media Playback -->
                <GroupBox Header="Media Playback" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{StaticResource MutedTextBrush}">
                            Control whether audio or video continues playing when you switch tabs.
                        </TextBlock>
                        <CheckBox x:Name="AllowBackgroundAudioCheckBox"
                                  Content="Allow audio to keep playing when switching tabs"
                                  AutomationProperties.Name="Allow background audio"
                                  Margin="0,0,0,6"
                                  Checked="MediaPreferenceChanged"
                                  Unchecked="MediaPreferenceChanged"/>
                        <CheckBox x:Name="AllowBackgroundVideoCheckBox"
                                  Content="Allow video to keep playing when switching tabs"
                                  AutomationProperties.Name="Allow background video"
                                  Margin="0,0,0,6"
                                  Checked="MediaPreferenceChanged"
                                  Unchecked="MediaPreferenceChanged"/>
                        <CheckBox x:Name="PreventAudioVideoOverlapCheckBox"
                                  Content="Prevent audio and video from playing at the same time"
                                  AutomationProperties.Name="Prevent audio video overlap"
                                  Checked="MediaPreferenceChanged"
                                  Unchecked="MediaPreferenceChanged"/>
                        <TextBlock Text="Note: If overlap prevention is enabled, starting video will stop audio (even if background audio is allowed)."
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>


                <!-- Config path info -->
                <TextBlock x:Name="ConfigPathTextBlock"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
