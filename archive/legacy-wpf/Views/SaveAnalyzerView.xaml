<UserControl x:Class="Onslaught___Career_Editor.Views.SaveAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800">
    <Grid Margin="10" Grid.IsSharedSizeScope="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="240"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="File Selection" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Detected Files:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="SaveFilesComboBox"
                                      Grid.Column="1"
                                      TabIndex="0"
                                      AutomationProperties.Name="Select detected file"
                                      SelectionChanged="SaveFilesComboBox_SelectionChanged"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="Refresh"
                                    TabIndex="1"
                                    AutomationProperties.Name="Refresh file list"
                                    ToolTip="Refresh detected .bes/.bea files"
                                    Click="RefreshSaveFiles_Click"
                                    Padding="10,4"
                                    MinWidth="90"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Input File:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="FilePathTextBox"
                                     Grid.Column="1"
                                     TabIndex="2"
                                     AutomationProperties.Name="File path"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="Browse..."
                                    TabIndex="3"
                                    AutomationProperties.Name="Browse for file"
                                    Click="BrowseButton_Click"
                                    Padding="12,4"
                                    MinWidth="90"
                                    ToolTip="Browse for a .bes/.bea file to analyze"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button x:Name="AnalyzeButton"
                                    Content="Analyze / Reload"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    TabIndex="4"
                                    AutomationProperties.Name="Analyze file"
                                    Click="AnalyzeButton_Click"
                                    Padding="12,4"
                                    MinWidth="110"
                                    Margin="0,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="Analyze the selected .bes/.bea file structure or reload the current file from disk."/>
                            <Button x:Name="RefreshButton"
                                    Content="Analyze Again"
                                    TabIndex="5"
                                    AutomationProperties.Name="Refresh analysis"
                                    Click="RefreshButton_Click"
                                    Padding="12,4"
                                    MinWidth="110"
                                    Visibility="Collapsed"
                                    IsEnabled="False"
                                    ToolTip="Re-analyze the current file"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,8,0,0">
                            Picking a detected file auto-runs analysis. Use Analyze / Reload when you want to re-read the same file after external changes or after changing display options.
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Display Options" Margin="0,0,0,10">
                    <StackPanel Margin="10,5">
                        <Border Style="{StaticResource InfoCalloutBorderStyle}" Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource CalloutTextStyle}">
                                `.bes` analysis shows stored career progress. `.bea` analysis shows the boot-time global options snapshot that retail Steam uses for keybinds and most configuration values.
                            </TextBlock>
                        </Border>
                        <CheckBox x:Name="VerboseCheckBox"
                                  Content="Verbose (nodes + bindings)"
                                  TabIndex="6"
                                  Checked="VerboseCheckBox_Changed"
                                  Unchecked="VerboseCheckBox_Changed"
                                  ToolTip="Show detailed node info and decoded options bindings/tail fields (when present)."/>
                        <CheckBox x:Name="DumpMysteryCheckBox"
                                  Content="Raw reserved-byte dump (advanced)"
                                  TabIndex="7"
                                  Checked="DumpMysteryCheckBox_Changed"
                                  Unchecked="DumpMysteryCheckBox_Changed"
                                  Margin="0,4,0,0"
                                  ToolTip="Include hex dumps of unmapped/reserved bytes. These regions are preserved by default."/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Compare Files" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Compare File:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="CompareFileTextBox"
                                     Grid.Column="1"
                                     TabIndex="8"
                                     AutomationProperties.Name="Compare file path"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     ToolTip="Second file to compare with"/>
                            <Button Grid.Column="2"
                                    Content="Browse..."
                                    TabIndex="9"
                                    AutomationProperties.Name="Browse for compare file"
                                    Click="BrowseCompareButton_Click"
                                    Padding="10,4"
                                    MinWidth="90"
                                    ToolTip="Browse for a second file to compare"/>
                        </Grid>
                        <Button x:Name="CompareButton"
                                Content="Compare Files"
                                Style="{StaticResource PrimaryButtonStyle}"
                                TabIndex="10"
                                AutomationProperties.Name="Compare files button"
                                Click="CompareButton_Click"
                                Padding="12,4"
                                MinWidth="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                IsEnabled="False"
                                ToolTip="Compare the two selected files byte-by-byte"/>
                        <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,8,0,0">
                            Comparison mode replaces the summary tree with comparison totals and region counts so the left panel matches the report on the right.
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="SummaryGroupBox" Header="Analysis Summary" Margin="0,0,0,0">
                    <TreeView x:Name="SummaryTree"
                              TabIndex="11"
                              AutomationProperties.Name="Analysis summary tree"
                              Margin="5"
                              BorderThickness="0"
                              MinHeight="150">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      AutomationProperties.Name="Resize panel splitter"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource CardBorderBrush}"/>

        <DockPanel Grid.Column="2">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TitleBlock"
                               Text="Save/Options Analyzer"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ModeTextBlock"
                               Style="{StaticResource HelperTextStyle}"
                               Text="Single-file analysis: choose a .bes or .bea file to inspect."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CopyButton"
                            Content="Copy to Clipboard"
                            TabIndex="12"
                            AutomationProperties.Name="Copy to clipboard button"
                            Click="CopyButton_Click"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            ToolTip="Copy analysis output to clipboard"/>
                    <Button x:Name="ClearButton"
                            Content="Clear"
                            TabIndex="13"
                            AutomationProperties.Name="Clear output button"
                            Click="ClearButton_Click"
                            Padding="10,4"
                            ToolTip="Clear analysis output and summary"/>
                </StackPanel>
            </Grid>

            <Border BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{StaticResource SurfaceMutedBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OutputTextBlock"
                               Padding="10"
                               TextWrapping="NoWrap"
                               FontFamily="Consolas"
                               FontSize="11"/>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
