<UserControl x:Class="Onslaught___Career_Editor.Views.LoreBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Document Tree -->
        <DockPanel Grid.Column="0">
            <!-- Search Box and Refresh -->
            <StackPanel DockPanel.Dock="Top" Margin="8,8,8,6">
                <Label Content="Search:"
                       FontWeight="SemiBold"
                       Target="{Binding ElementName=SearchTextBox}"
                       Padding="0"
                       Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             TabIndex="0"
                             AutomationProperties.Name="Search documents"
                             TextChanged="SearchTextBox_TextChanged"
                             ToolTip="Filter documents by name or content"
                             MinHeight="28"
                             Padding="6,2"
                             Margin="0"/>
                    <Button Grid.Column="1" Content="Refresh" Click="RefreshButton_Click"
                            TabIndex="1"
                            AutomationProperties.Name="Refresh document list"
                            Padding="12,4"
                            FontSize="11"
                            MinHeight="28"
                            Margin="8,0,0,0"
                            ToolTip="Rescan documentation directories"/>
                </Grid>
            </StackPanel>

            <!-- Document Tree -->
            <Border Margin="8,0,8,8"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4">
                <TreeView x:Name="DocumentTree"
                          TabIndex="3"
                          AutomationProperties.Name="Document navigation tree"
                          Margin="4"
                          SelectedItemChanged="DocumentTree_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" ToolTip="{Binding FilePath}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="6"
                      AutomationProperties.Name="Resize panel splitter"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource CardBorderBrush}"/>

        <!-- Right Panel: Content Display -->
        <DockPanel Grid.Column="2">
            <!-- Title + Navigation -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1"
                    Padding="10,10,10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BackButton"
                            Grid.Column="0"
                            Content="← Back"
                            TabIndex="3"
                            AutomationProperties.Name="Back navigation"
                            Click="BackButton_Click"
                            Padding="10,2"
                            MinHeight="28"
                            IsEnabled="False"
                            ToolTip="Go to previous document"/>
                    <Button x:Name="ForwardButton"
                            Grid.Column="1"
                            Content="Forward →"
                            TabIndex="4"
                            AutomationProperties.Name="Forward navigation"
                            Click="ForwardButton_Click"
                            Padding="10,2"
                            MinHeight="28"
                            Margin="6,0,0,0"
                            IsEnabled="False"
                            ToolTip="Go to next document"/>
                    <Button x:Name="HomeButton"
                            Grid.Column="2"
                            Content="Home"
                            TabIndex="5"
                            AutomationProperties.Name="Home navigation"
                            Click="HomeButton_Click"
                            Padding="10,2"
                            MinHeight="28"
                            Margin="6,0,0,0"
                            ToolTip="Return to the book overview"/>
                    <TextBlock x:Name="TitleBlock"
                               Grid.Column="3"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- Content Browser -->
            <Border Margin="10,8,10,10"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4">
                <wv2:WebView2 x:Name="ContentBrowser"
                              NavigationStarting="ContentBrowser_NavigationStarting"
                              NavigationCompleted="ContentBrowser_NavigationCompleted"/>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
