<UserControl x:Class="Onslaught___Career_Editor.Views.VideoPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="10,10,10,6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" MinWidth="220"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource InsetCardBorderStyle}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Video library"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Browse main videos, cutscenes, and mission briefings. Double-click a file to start playback."
                               Style="{StaticResource HelperTextStyle}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="SearchTextBox"
                             TabIndex="0"
                             AutomationProperties.Name="Search videos"
                             TextChanged="SearchTextBox_TextChanged"
                             ToolTip="Filter videos"/>
                </StackPanel>

                <TreeView x:Name="VideoTree"
                          Grid.Row="1"
                          TabIndex="1"
                          AutomationProperties.Name="Video file tree"
                          SelectedItemChanged="VideoTree_SelectedItemChanged"
                          MouseDoubleClick="VideoTree_MouseDoubleClick">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" DockPanel.Dock="Right"/>
                            </DockPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Margin="6,2"
                      Background="{StaticResource SurfaceStrongBrush}"
                      BorderThickness="0"
                      AutomationProperties.Name="Resize panel splitter"/>

        <Grid Grid.Column="2" Margin="0,0,0,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource InsetCardBorderStyle}"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Now playing"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock x:Name="VideoTitleLabel"
                               Text="No video selected"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="VideoPathLabel"
                               Margin="0,6,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="Black"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    MinHeight="300"
                    Margin="0,0,0,10">
                <Grid ClipToBounds="True">
                    <vlc:VideoView x:Name="VideoView"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>
                    <Border x:Name="VideoEmptyStateOverlay"
                            Background="#82000000"
                            Visibility="Visible"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="VideoEmptyStateText"
                                   Text="Select a video from the library."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource InsetCardBorderStyle}"
                    Padding="14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeLabel"
                                   Grid.Column="0"
                                   Text="0:00"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <Slider x:Name="ProgressSlider"
                                Grid.Column="1"
                                TabIndex="2"
                                AutomationProperties.Name="Video playback progress"
                                Margin="12,0"
                                ValueChanged="ProgressSlider_ValueChanged"
                                PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                                PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                                IsEnabled="False"/>
                        <TextBlock x:Name="TotalTimeLabel"
                                   Grid.Column="2"
                                   Text="0:00"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="PlayButton" Content="Play" Click="PlayButton_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    TabIndex="3"
                                    AutomationProperties.Name="Play video button"
                                    Padding="16,8" Margin="0,0,6,0" MinWidth="80" MinHeight="36" IsEnabled="False"
                                    ToolTip="Start playback"/>
                            <Button x:Name="PauseButton" Content="Pause" Click="PauseButton_Click"
                                    TabIndex="4"
                                    AutomationProperties.Name="Pause video button"
                                    Padding="16,8" Margin="0,0,6,0" MinWidth="80" MinHeight="36" IsEnabled="False"
                                    ToolTip="Pause playback"/>
                            <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click"
                                    TabIndex="5"
                                    AutomationProperties.Name="Stop video button"
                                    Padding="16,8" MinWidth="80" MinHeight="36" IsEnabled="False"
                                    ToolTip="Stop playback"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Volume"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       FontWeight="SemiBold"/>
                            <Slider x:Name="VolumeSlider"
                                    TabIndex="6"
                                    AutomationProperties.Name="Video volume slider"
                                    Width="130"
                                    Minimum="0" Maximum="100" Value="75"
                                    ValueChanged="VolumeSlider_ValueChanged"/>
                            <TextBlock x:Name="VideoVolumeLabel"
                                       Text="75%"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="10,0,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentDarkBrush}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource InsetCardBorderStyle}"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Game directory"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Video discovery reads from the installed game directory. Reload after changing the path or updating files."
                               Style="{StaticResource HelperTextStyle}"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GameDirTextBox"
                                 Grid.Column="0"
                                 TabIndex="7"
                                 AutomationProperties.Name="Game directory path"
                                 IsReadOnly="True"
                                 Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="Browse..."
                                TabIndex="8"
                                AutomationProperties.Name="Browse for game directory"
                                Click="BrowseGameDir_Click"
                                Padding="14,7"
                                ToolTip="Browse for game installation directory"/>
                    </Grid>
                    <Button Content="Reload Videos"
                            TabIndex="9"
                            AutomationProperties.Name="Reload video files"
                            Click="ReloadVideo_Click"
                            Margin="0,10,0,0"
                            Padding="12,7"
                            HorizontalAlignment="Left"
                            ToolTip="Rescan game directory for video files"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
