<UserControl x:Class="Onslaught___Career_Editor.Views.SaveEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="680">
    <Grid Margin="10" Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- File Selection -->
                    <GroupBox Header="File Selection" Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel Margin="10">
                            <Border x:Name="ModeBannerBorder"
                                    Style="{StaticResource InfoCalloutBorderStyle}"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,8">
                                <TextBlock x:Name="ModeBannerText"
                                           Style="{StaticResource CalloutTextStyle}"
                                           FontWeight="SemiBold"
                                           Text="Configuration Editor mode: use this tab for global settings in defaultoptions.bea. Career progression sections are hidden to reduce accidental writes."/>
                            </Border>

                            <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8">
                                Pick a detected file or browse manually. Output stays separate so `.bes` edits default to a new patched copy.
                            </TextBlock>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Quick Select:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <ComboBox Grid.Column="1"
                                          x:Name="SaveFilesComboBox"
                                          TabIndex="0"
                                          AutomationProperties.Name="Quick select file"
                                          SelectionChanged="SaveFilesComboBox_SelectionChanged"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"/>

                                <Button Grid.Column="2"
                                        Content="Refresh"
                                        TabIndex="1"
                                        AutomationProperties.Name="Refresh file list"
                                        Click="RefreshSaveFiles_Click"
                                        Padding="15,5"
                                        MinWidth="80"
                                        ToolTip="Scan game directory for files relevant to this tab"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Input File:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <TextBox Grid.Column="1"
                                         x:Name="InputFileTextBox"
                                         TabIndex="2"
                                         AutomationProperties.Name="Input file path"
                                         IsReadOnly="True"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <Button Grid.Column="2"
                                        x:Name="BrowseInputButton"
                                        Content="Browse..."
                                        TabIndex="3"
                                        AutomationProperties.Name="Browse for input file"
                                        Click="BrowseInputButton_Click"
                                        Padding="15,5"
                                        MinWidth="80"
                                        ToolTip="Browse for an input file for this editor mode"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FieldLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Output File:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <TextBox Grid.Column="1"
                                         x:Name="OutputFileTextBox"
                                         TabIndex="4"
                                         AutomationProperties.Name="Output file path"
                                         IsReadOnly="True"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <Button Grid.Column="2"
                                        x:Name="BrowseOutputButton"
                                        Content="Browse..."
                                        TabIndex="5"
                                        AutomationProperties.Name="Browse for output file"
                                        Click="BrowseOutputButton_Click"
                                        Padding="15,5"
                                        MinWidth="80"
                                        ToolTip="Choose where to save the patched file"/>
                            </Grid>

                            <TextBlock x:Name="OutputPathHintText"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Patch Options -->
                    <GroupBox x:Name="PatchOptionsGroupBox" Header="Quick Patch Defaults" Grid.Column="1">
                        <StackPanel Margin="10">
                            <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,10">
                                These defaults drive the broad patch actions. Advanced Options below handle per-mission, per-category, and per-binding overrides.
                            </TextBlock>

                            <Border Style="{StaticResource InsetCardBorderStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Mission rank baseline" />
                                    <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6">
                                        Used for every mission row that stays on Keep.
                                    </TextBlock>
                                    <ComboBox x:Name="RankComboBox"
                                              TabIndex="6"
                                              AutomationProperties.Name="Mission rank selection"
                                              SelectedIndex="0"
                                              ToolTip="Default grade used when a mission row is set to Keep. S-E are verified. NONE writes -1.0 (no grade shown in UI).">
                                        <ComboBoxItem Content="S" Tag="S"/>
                                        <ComboBoxItem Content="A" Tag="A"/>
                                        <ComboBoxItem Content="B" Tag="B"/>
                                        <ComboBoxItem Content="C" Tag="C"/>
                                        <ComboBoxItem Content="D" Tag="D"/>
                                        <ComboBoxItem Content="E" Tag="E"/>
                                        <ComboBoxItem Content="No Grade (undefined)" Tag="NONE"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetCardBorderStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Goodie presentation" />
                                    <CheckBox x:Name="NewGoodiesCheckBox"
                                              Content="Mark goodies as NEW"
                                              TabIndex="7"
                                              Margin="0,4,0,0"
                                              ToolTip="Shows gold 'NEW' badge instead of blue 'OLD'"/>
                                    <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,6,0,0">
                                        Cosmetic only. Gold shows NEW, blue shows OLD.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Default kill value for unchecked categories" />
                                    <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6">
                                        Not cumulative. When Kill Counts is enabled, this value is written to any category you leave unchecked below.
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="KillCountSlider" Grid.Column="0"
                                                TabIndex="8"
                                                AutomationProperties.Name="Kill count slider"
                                                Minimum="0" Maximum="65535" Value="100"
                                                TickFrequency="1000" IsSnapToTickEnabled="False"
                                                TickPlacement="BottomRight"
                                                ValueChanged="KillCountSlider_ValueChanged"
                                                VerticalAlignment="Center"/>
                                        <TextBox x:Name="KillCountTextBox" Grid.Column="1"
                                                 TabIndex="9"
                                                 AutomationProperties.Name="Kill count value"
                                                 Text="100"
                                                 TextAlignment="Center"
                                                 KeyDown="KillCountTextBox_KeyDown"
                                                 LostFocus="KillCountTextBox_LostFocus"
                                                 VerticalAlignment="Center"
                                                 Margin="10,0,0,0"/>
                                    </Grid>
                                    <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,6,0,0">
                                        Drag for common values up to 65,535. Type higher values manually up to 16,777,215 if you need an extreme global count.
                                    </TextBlock>
                                    <TextBlock x:Name="KillBaselineSummaryText"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="Loaded file state is shown in the Current column below. Mixed category values are kept visible per row."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                </Grid>

        <!-- Patch Sections -->
        <GroupBox x:Name="PatchSectionsGroupBox" Header="Patch Sections" Margin="0,0,0,10">
            <StackPanel Margin="10,5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Patch preset:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PatchPresetComboBox"
                              Width="180"
                              SelectedIndex="1"
                              SelectionChanged="PatchPresetComboBox_SelectionChanged"
                              ToolTip="Quick Unlock enables all career sections. Safe Edit starts with sections disabled.">
                        <ComboBoxItem Content="Quick Unlock" Tag="QUICK"/>
                        <ComboBoxItem Content="Safe Edit" Tag="SAFE"/>
                        <ComboBoxItem Content="Custom" Tag="CUSTOM"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8">
                    Uncheck to preserve existing save data in specific sections.
                </TextBlock>
                <UniformGrid Columns="2" Margin="0,0,0,4">
                    <CheckBox x:Name="PatchNodesCheckBox" Content="Mission Nodes"
                              TabIndex="10"
                              Checked="PatchSectionCheckBox_Changed"
                              Unchecked="PatchSectionCheckBox_Changed"
                              IsChecked="False" Margin="0,0,15,4"
                              ToolTip="Patches all 43 mission nodes with selected rank"/>
                    <CheckBox x:Name="PatchLinksCheckBox" Content="Mission Links"
                              TabIndex="11"
                              Checked="PatchSectionCheckBox_Changed"
                              Unchecked="PatchSectionCheckBox_Changed"
                              IsChecked="False" Margin="0,0,15,4"
                              ToolTip="Completes all used mission links (preserves non-zero types; leaves unused entries unchanged)"/>
                    <CheckBox x:Name="PatchGoodiesCheckBox" Content="Goodies"
                              TabIndex="12"
                              Checked="PatchSectionCheckBox_Changed"
                              Unchecked="PatchSectionCheckBox_Changed"
                              IsChecked="False" Margin="0,0,15,4"
                              ToolTip="Unlocks all displayable goodies (233). Leaves reserved entries unchanged."/>
                    <CheckBox x:Name="PatchKillsCheckBox" Content="Kill Counts"
                              TabIndex="13"
                              Checked="PatchSectionCheckBox_Changed"
                              Unchecked="PatchSectionCheckBox_Changed"
                              IsChecked="False" Margin="0,0,15,4"
                              ToolTip="Sets kill counts for all 5 categories"/>
                </UniformGrid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <CheckBox x:Name="KillsOnlyCheckBox" Content="Kills Only Mode"
                              TabIndex="14"
                              Margin="0,0,10,0"
                              Checked="KillsOnlyCheckBox_Changed"
                              Unchecked="KillsOnlyCheckBox_Changed"
                              ToolTip="Only patch kill counts (preserves nodes, links, goodies)"/>
                    <TextBlock Text="(useful for unlocking kill-based goodies without changing progress)"
                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </GroupBox>

        <!-- Advanced Options -->
        <GroupBox x:Name="AdvancedOptionsGroupBox" Header="Advanced Options" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <CheckBox x:Name="ShowAdvancedCheckBox"
                          Content="Show advanced override sections"
                          TabIndex="15"
                          Margin="0,0,0,8"
                          IsChecked="False"
                          Checked="ShowAdvancedCheckBox_Changed"
                          Unchecked="ShowAdvancedCheckBox_Changed"/>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,10">
                    Advanced controls stay collapsed until you expand a section. Career progress, settings, and keybind/global panels are separated to reduce accidental edits.
                </TextBlock>

                <StackPanel x:Name="AdvancedOptionsPanel" Visibility="Collapsed">
                    <Expander x:Name="CareerProgressExpander"
                              Header="Career Progress Overrides (.bes)"
                              Style="{StaticResource AdvancedSectionExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel x:Name="CareerAdvancedSectionsPanel" Margin="0,6,0,0">
                <!-- Per-Level Rank Overrides -->
                <TextBlock Text="Per-Mission Rank Overrides" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6">
                    Use this grid to override specific campaign missions. Leave a row on Keep to use the default rank above.
                </TextBlock>
	                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
	                    <Button x:Name="SetMissionRanksToDefaultButton"
	                            Content="Set All To Default Rank"
                            TabIndex="16"
                            Click="SetMissionRanksToDefaultButton_Click"
                            Padding="10,3"
                            Margin="0,0,8,0"
                            ToolTip="Set every mission override row to the current default rank selection."/>
                    <Button x:Name="ClearMissionRanksButton"
	                            Content="Clear Mission Overrides"
	                            TabIndex="17"
	                            Click="ClearMissionRanksButton_Click"
	                            Padding="10,3"
	                            ToolTip="Set every mission row back to Keep (no per-mission override)."/>
	                </StackPanel>
                <DataGrid x:Name="MissionRanksDataGrid"
                          TabIndex="18"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          Height="300"
                          Margin="0,0,0,12"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Node"
                                            Binding="{Binding NodeLabel}"
                                            IsReadOnly="True"
                                            Width="70"/>
                        <DataGridTextColumn Header="Mission"
                                            Binding="{Binding MissionLabel}"
                                            IsReadOnly="True"
                                            Width="*"/>
                        <DataGridTextColumn Header="Current Rank"
                                            Binding="{Binding CurrentRank}"
                                            IsReadOnly="True"
                                            Width="130"/>
                        <DataGridTemplateColumn Header="Rank Override" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedRank}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding RankChoices}"
                                              SelectedItem="{Binding SelectedRank, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Per-Category Kill Counts -->
                <TextBlock Text="Per-Category Kill Overrides" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8">
                    Current values come from the loaded save. Enable a category to write a custom value for that row; unchecked rows use the default kill value above.
                </TextBlock>
                <Border Style="{StaticResource InsetCardBorderStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="76"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Category" FontWeight="SemiBold" Margin="0,0,8,8"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Current" FontWeight="SemiBold" Margin="0,0,8,8" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Override" FontWeight="SemiBold" Margin="0,0,8,8"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Write" FontWeight="SemiBold" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                    <CheckBox x:Name="AircraftOverrideCheckBox"
                              Grid.Row="1" Grid.Column="0"
                              Content="Aircraft (25/50/75/100)"
                              TabIndex="19"
                              Margin="0,0,8,8"
                              Checked="CategoryKillOverrideCheckBox_Changed"
                              Unchecked="CategoryKillOverrideCheckBox_Changed"/>
                    <TextBlock x:Name="AircraftCurrentKillsTextBlock"
                               Grid.Row="1" Grid.Column="1"
                               Text="100"
                               Margin="0,0,8,8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="AircraftKillsSlider"
                            Grid.Row="1" Grid.Column="2"
                            TabIndex="20"
                            Minimum="0" Maximum="100" Value="100"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            ValueChanged="CategoryKillSlider_ValueChanged"
                            IsEnabled="False"
                            Margin="0,0,8,8"/>
                    <TextBox x:Name="AircraftKillsTextBox"
                             Grid.Row="1" Grid.Column="3"
                             TabIndex="21"
                             IsEnabled="False"
                             Text="100"
                             LostFocus="CategoryKillTextBox_LostFocus"
                             KeyDown="CategoryKillTextBox_KeyDown"
                             ToolTip="Aircraft kills override. Slider range is 0-100; you can type a higher value manually."
                             HorizontalContentAlignment="Center"
                             Margin="0,0,0,8"/>

                    <CheckBox x:Name="VehicleOverrideCheckBox"
                              Grid.Row="2" Grid.Column="0"
                              Content="Vehicles (100/200/300/400)"
                              TabIndex="22"
                              Margin="0,0,8,8"
                              Checked="CategoryKillOverrideCheckBox_Changed"
                              Unchecked="CategoryKillOverrideCheckBox_Changed"/>
                    <TextBlock x:Name="VehicleCurrentKillsTextBlock"
                               Grid.Row="2" Grid.Column="1"
                               Text="100"
                               Margin="0,0,8,8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="VehicleKillsSlider"
                            Grid.Row="2" Grid.Column="2"
                            TabIndex="23"
                            Minimum="0" Maximum="400" Value="100"
                            TickFrequency="10"
                            IsSnapToTickEnabled="False"
                            ValueChanged="CategoryKillSlider_ValueChanged"
                            IsEnabled="False"
                            Margin="0,0,8,8"/>
                    <TextBox x:Name="VehicleKillsTextBox"
                             Grid.Row="2" Grid.Column="3"
                             TabIndex="24"
                             IsEnabled="False"
                             Text="100"
                             LostFocus="CategoryKillTextBox_LostFocus"
                             KeyDown="CategoryKillTextBox_KeyDown"
                             ToolTip="Vehicle kills override. Slider range is 0-400; you can type a higher value manually."
                             HorizontalContentAlignment="Center"
                             Margin="0,0,0,8"/>

                    <CheckBox x:Name="EmplacementOverrideCheckBox"
                              Grid.Row="3" Grid.Column="0"
                              Content="Emplacements (25/50/75*)"
                              TabIndex="25"
                              Margin="0,0,8,8"
                              Checked="CategoryKillOverrideCheckBox_Changed"
                              Unchecked="CategoryKillOverrideCheckBox_Changed"/>
                    <TextBlock x:Name="EmplacementCurrentKillsTextBlock"
                               Grid.Row="3" Grid.Column="1"
                               Text="25"
                               Margin="0,0,8,8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="EmplacementKillsSlider"
                            Grid.Row="3" Grid.Column="2"
                            TabIndex="26"
                            Minimum="0" Maximum="75" Value="25"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            ValueChanged="CategoryKillSlider_ValueChanged"
                            IsEnabled="False"
                            Margin="0,0,8,8"/>
                    <TextBox x:Name="EmplacementKillsTextBox"
                             Grid.Row="3" Grid.Column="3"
                             TabIndex="27"
                             IsEnabled="False"
                             Text="25"
                             LostFocus="CategoryKillTextBox_LostFocus"
                             KeyDown="CategoryKillTextBox_KeyDown"
                             ToolTip="Emplacement kills override. Slider range is 0-75; you can type a higher value manually."
                             HorizontalContentAlignment="Center"
                             Margin="0,0,0,8"/>

                    <CheckBox x:Name="InfantryOverrideCheckBox"
                              Grid.Row="4" Grid.Column="0"
                              Content="Infantry (40/80/160)"
                              TabIndex="28"
                              Margin="0,0,8,8"
                              Checked="CategoryKillOverrideCheckBox_Changed"
                              Unchecked="CategoryKillOverrideCheckBox_Changed"/>
                    <TextBlock x:Name="InfantryCurrentKillsTextBlock"
                               Grid.Row="4" Grid.Column="1"
                               Text="40"
                               Margin="0,0,8,8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="InfantryKillsSlider"
                            Grid.Row="4" Grid.Column="2"
                            TabIndex="29"
                            Minimum="0" Maximum="160" Value="40"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            ValueChanged="CategoryKillSlider_ValueChanged"
                            IsEnabled="False"
                            Margin="0,0,8,8"/>
                    <TextBox x:Name="InfantryKillsTextBox"
                             Grid.Row="4" Grid.Column="3"
                             TabIndex="30"
                             IsEnabled="False"
                             Text="40"
                             LostFocus="CategoryKillTextBox_LostFocus"
                             KeyDown="CategoryKillTextBox_KeyDown"
                             ToolTip="Infantry kills override. Slider range is 0-160; you can type a higher value manually."
                             HorizontalContentAlignment="Center"
                             Margin="0,0,0,8"/>

                    <CheckBox x:Name="MechOverrideCheckBox"
                              Grid.Row="5" Grid.Column="0"
                              Content="Mechs (20/40/80)"
                              TabIndex="31"
                              Margin="0,0,8,0"
                              Checked="CategoryKillOverrideCheckBox_Changed"
                              Unchecked="CategoryKillOverrideCheckBox_Changed"/>
                    <TextBlock x:Name="MechCurrentKillsTextBlock"
                               Grid.Row="5" Grid.Column="1"
                               Text="20"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="MechKillsSlider"
                            Grid.Row="5" Grid.Column="2"
                            Minimum="0" Maximum="80" Value="20"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            ValueChanged="CategoryKillSlider_ValueChanged"
                            IsEnabled="False"
                            Margin="0,0,8,0"/>
				                    <TextBox x:Name="MechKillsTextBox"
				                             Grid.Row="5" Grid.Column="3"
				                             IsEnabled="False"
				                             Text="20"
			                             LostFocus="CategoryKillTextBox_LostFocus"
			                             KeyDown="CategoryKillTextBox_KeyDown"
			                             ToolTip="Mech kills override. Slider range is 0-80; you can type a higher value manually."
			                             HorizontalContentAlignment="Center"
		                             Margin="0,0,0,0"/>
	                </Grid>
                    </Border>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="CareerSettingsExpander"
                              Header="Career Settings Overrides"
                              Style="{StaticResource AdvancedSectionExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Margin="0,6,0,0">
		                <TextBlock x:Name="CareerSettingsDescriptionTextBlock" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8">
		                    Optional: override settings stored in the fixed CCareer block. Leave blank / Keep to preserve existing values.
		                </TextBlock>
                <Border Style="{StaticResource WarningCalloutBorderStyle}" Margin="0,0,0,8">
                    <TextBlock x:Name="CareerSettingsSteamNoteTextBlock" Style="{StaticResource CalloutTextStyle}">
                        Note (Steam build): loading a .bes save preserves current Sound/Music volumes and does not immediately apply options entries/tail (keybinds, mouse sensitivity, screen shape). For deterministic global settings changes, patch defaultoptions.bea directly; alternatively, load/save frontend flows can sync a .bes buffer into defaultoptions.bea for next boot (restart still required).
		                </TextBlock>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Volumes -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                        <CheckBox x:Name="OverrideSoundVolumeCheckBox"
                                  Content="Override Sound Volume"
                                  Margin="0,0,0,4"
                                  Checked="VolumeOverrideCheckBox_Changed"
                                  Unchecked="VolumeOverrideCheckBox_Changed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SoundVolumeSlider"
                                    Grid.Column="0"
                                    Minimum="0" Maximum="1" Value="0.8"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    IsEnabled="False"
                                    Margin="0,0,8,0"/>
                            <TextBox x:Name="SoundVolumeTextBox"
                                     Grid.Column="1"
                                     AutomationProperties.Name="Sound volume override"
                                     IsReadOnly="True"
                                     IsEnabled="False"
                                     Text="{Binding ElementName=SoundVolumeSlider, Path=Value, StringFormat={}{0:0.00}}"
                                     HorizontalContentAlignment="Center"
                                     ToolTip="Enable override to write this value (0.0-1.0)."/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <CheckBox x:Name="OverrideMusicVolumeCheckBox"
                                  Content="Override Music Volume"
                                  Margin="0,0,0,4"
                                  Checked="VolumeOverrideCheckBox_Changed"
                                  Unchecked="VolumeOverrideCheckBox_Changed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="MusicVolumeSlider"
                                    Grid.Column="0"
                                    Minimum="0" Maximum="1" Value="0.8"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    IsEnabled="False"
                                    Margin="0,0,8,0"/>
                            <TextBox x:Name="MusicVolumeTextBox"
                                     Grid.Column="1"
                                     AutomationProperties.Name="Music volume override"
                                     IsReadOnly="True"
                                     IsEnabled="False"
                                     Text="{Binding ElementName=MusicVolumeSlider, Path=Value, StringFormat={}{0:0.00}}"
                                     HorizontalContentAlignment="Center"
                                     ToolTip="Enable override to write this value (0.0-1.0)."/>
                        </Grid>
                    </StackPanel>

                    <!-- Row 1: Invert Y (Walker Mode) -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock Text="Invert Y (Walker) (P1)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="InvertYP1ComboBox"
                                  TabIndex="32"
                                  AutomationProperties.Name="Invert Y (Walker) player 1 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. Affects mouse look pitch inversion (Walker mode). 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="Invert Y (Walker) (P2)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="InvertYP2ComboBox"
                                  TabIndex="33"
                                  AutomationProperties.Name="Invert Y (Walker) player 2 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. Affects mouse look pitch inversion (Walker mode). 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Row 2: Invert Y (Flight Mode) -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock Text="Invert Y (Flight) (P1)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="InvertFlightP1ComboBox"
                                  TabIndex="34"
                                  AutomationProperties.Name="Invert Y (Flight) player 1 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. Affects mouse look pitch inversion (Flight/Jet mode). 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="Invert Y (Flight) (P2)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="InvertFlightP2ComboBox"
                                  TabIndex="35"
                                  AutomationProperties.Name="Invert Y (Flight) player 2 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. Affects mouse look pitch inversion (Flight/Jet mode). 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Row 3: Controller config -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock Text="Controller Config (P1)" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="ControllerConfigP1TextBox"
                                 TabIndex="36"
                                 AutomationProperties.Name="Controller config player 1 override"
                                 ToolTip="Optional override. Raw index value. Leave blank to preserve."/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="Controller Config (P2)" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="ControllerConfigP2TextBox"
                                 TabIndex="37"
                                 AutomationProperties.Name="Controller config player 2 override"
                                 ToolTip="Optional override. Raw index value. Leave blank to preserve."/>
                    </StackPanel>

                    <!-- Row 4: Vibration -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Controller Vibration (P1)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ControllerVibrationP1ComboBox"
                                  TabIndex="38"
                                  AutomationProperties.Name="Controller vibration player 1 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,0">
                        <TextBlock Text="Controller Vibration (P2)" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ControllerVibrationP2ComboBox"
                                  TabIndex="39"
                                  AutomationProperties.Name="Controller vibration player 2 override"
                                  SelectedIndex="0"
                                  ToolTip="Optional override. Keep preserves the save value. 0=Off, non-zero=On.">
                            <ComboBoxItem Content="Keep" Tag="KEEP"/>
                            <ComboBoxItem Content="On" Tag="ON"/>
                            <ComboBoxItem Content="Off" Tag="OFF"/>
	                        </ComboBox>
	                    </StackPanel>
	                </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="KeybindSettingsExpander"
                              Header="Keybind and Global Settings Overrides (Advanced)"
                              Style="{StaticResource AdvancedSectionExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Margin="0,6,0,0">

	                <!-- Options entries + tail snapshot copy (raw byte copy) -->
                <TextBlock Text="Copy Keybind/Global Settings From File (Optional)" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <Border Style="{StaticResource InfoCalloutBorderStyle}" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource CalloutTextStyle}">
                        Copies the persisted options entries (keybinds) and/or the 0x56-byte tail snapshot (mouse sensitivity, screen shape, etc) from another .bes/.bea file.
                        Useful for syncing control bindings or transferring settings into defaultoptions.bea.
                        This source is used by Patch and by &quot;Load From Copy Source&quot;. It does not affect &quot;Load From Main Input&quot;.
                    </TextBlock>
                </Border>

                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <TextBox x:Name="CopyOptionsFromTextBox"
                             TabIndex="40"
                             AutomationProperties.Name="Copy options from path"
                             IsReadOnly="True"
                             ToolTip="Optional. If set, copy options entries/tail snapshot from this source file."
                             Margin="0,0,8,0"/>
                    <Button x:Name="BrowseCopyOptionsFromButton"
                            Content="Browse..."
                            TabIndex="41"
                            AutomationProperties.Name="Browse copy options from file button"
                            Click="BrowseCopyOptionsFromButton_Click"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            ToolTip="Select a source .bes/.bea to copy options from"/>
                    <Button x:Name="ClearCopyOptionsFromButton"
                            Content="Clear"
                            TabIndex="42"
                            AutomationProperties.Name="Clear copy options from file button"
                            Click="ClearCopyOptionsFromButton_Click"
                            Padding="12,4"
                            ToolTip="Clear the copy source path (disable options copy)"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="CopyOptionsEntriesCheckBox"
                              Content="Copy keybind entries (action bindings)"
                              IsChecked="False"
                              Margin="0,0,18,0"
                              ToolTip="Copies action-binding entries (movement, look, zoom, fire, etc.) from the source file."/>
                    <CheckBox x:Name="CopyOptionsTailCheckBox"
                              Content="Copy global settings snapshot (mouse/device/screen)"
                              IsChecked="False"
                              ToolTip="Copies global settings snapshot values (mouse sensitivity, screen shape, D3D device index, and related settings)."/>
                </StackPanel>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,4">
                    Enable either checkbox independently. For a full configuration clone into defaultoptions.bea, enable both.
                </TextBlock>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,4">
                    Controls/actions = the per-action keybind entries (movement/look/zoom/fire/etc). Tail = global snapshot fields (mouse sensitivity, language/screen/device indices, and related globals).
                </TextBlock>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,4">
                    These copy controls are enabled only after you select a copy-source file.
                </TextBlock>
                <Border Style="{StaticResource WarningCalloutBorderStyle}" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CalloutTextStyle}">
                        Note (Steam build): defaultoptions.bea is authoritative at boot for keybinds and most global options.
                        If .bes changes do not appear immediately, restart after a load/save flow (which may sync defaultoptions.bea), or patch defaultoptions.bea directly.
                    </TextBlock>
                </Border>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,4">
                    Patch order: copy options first (if enabled), then apply any keybind overrides below.
                </TextBlock>

                <!-- Keybind overrides (options entries) -->
                <TextBlock Text="Keybind Overrides (Options Entries)" FontWeight="SemiBold" Margin="0,16,0,6"/>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8">
                    Optional: override persisted control bindings directly (0x24BE options entries).
                    Leave blank to preserve the file's existing binding. Use values like: <Run FontFamily="Consolas">A</Run>, <Run FontFamily="Consolas">Num7</Run>, <Run FontFamily="Consolas">Up</Run>, <Run FontFamily="Consolas">Mouse</Run>, <Run FontFamily="Consolas">MouseX+</Run>, <Run FontFamily="Consolas">MouseY-</Run>, <Run FontFamily="Consolas">MouseWheelUp</Run>, <Run FontFamily="Consolas">MouseLeft</Run>, <Run FontFamily="Consolas">MouseRight</Run>.
                </TextBlock>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8">
                    If a field contains a value like <Run FontFamily="Consolas">vk=0x0000 scan=0x0027</Run>, that is a raw fallback token from the file. You can leave it unchanged to preserve the binding.
                </TextBlock>
                <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8">
                    If a keybind field turns red, the token is not writable for that action. Hover the field for the exact validation reason.
                </TextBlock>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="LoadKeybindsFromInputButton"
                            Content="Load From Main Input"
                            TabIndex="43"
                            AutomationProperties.Name="Load keybinds from input button"
                            Click="LoadKeybindsFromInputButton_Click"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            ToolTip="Populate the fields below from the main Input File (top of page). Does not use the copy source above."/>
                    <Button x:Name="LoadKeybindsFromCopySourceButton"
                            Content="Load From Copy Source"
                            TabIndex="44"
                            AutomationProperties.Name="Load keybinds from copy source button"
                            Click="LoadKeybindsFromCopySourceButton_Click"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            ToolTip="Populate the fields below from the Copy Controls/Options source file (if set)."/>
                    <Button x:Name="ClearKeybindOverridesButton"
                            Content="Clear Overrides"
                            TabIndex="45"
                            AutomationProperties.Name="Clear keybind overrides button"
                            Click="ClearKeybindOverridesButton_Click"
                            Padding="12,4"
                            ToolTip="Clear all keybind override fields (leave blank to preserve existing bindings)."/>
                </StackPanel>

                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6">
                    Mapping note: slot0 in file maps to the left in-game column, slot1 maps to the right in-game column.
                </TextBlock>
                <Border Style="{StaticResource InsetCardBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Action" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Player 1" FontWeight="SemiBold" HorizontalAlignment="Center" ToolTip="Slot0 in file (left in-game list)."/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Player 2" FontWeight="SemiBold" HorizontalAlignment="Center" ToolTip="Slot1 in file (right in-game list)."/>

                    <!-- Movement -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Movement: Forward" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="MoveForwardP1TextBox" TabIndex="46" Margin="0,4,8,0" ToolTip="Example: W, Up, Num8"/>
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="MoveForwardP2TextBox" TabIndex="47" Margin="0,4,0,0" ToolTip="Example: I, Up, Num8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Movement: Backward" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="MoveBackwardP1TextBox" TabIndex="48" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="MoveBackwardP2TextBox" TabIndex="49" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Movement: Left" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="MoveLeftP1TextBox" TabIndex="50" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="MoveLeftP2TextBox" TabIndex="51" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Movement: Right" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="MoveRightP1TextBox" TabIndex="52" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="MoveRightP2TextBox" TabIndex="53" Margin="0,4,0,0"/>

                    <!-- Look -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Look: Up" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="LookUpP1TextBox" TabIndex="54" Margin="0,4,8,0" ToolTip="Example: Mouse or Up"/>
                    <TextBox Grid.Row="5" Grid.Column="2" x:Name="LookUpP2TextBox" TabIndex="55" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Look: Down" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="LookDownP1TextBox" TabIndex="56" Margin="0,4,8,0" ToolTip="Example: Mouse or Down"/>
                    <TextBox Grid.Row="6" Grid.Column="2" x:Name="LookDownP2TextBox" TabIndex="57" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Look: Left" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="LookLeftP1TextBox" TabIndex="58" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="7" Grid.Column="2" x:Name="LookLeftP2TextBox" TabIndex="59" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Look: Right" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="8" Grid.Column="1" x:Name="LookRightP1TextBox" TabIndex="60" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="8" Grid.Column="2" x:Name="LookRightP2TextBox" TabIndex="61" Margin="0,4,0,0"/>

                    <!-- Zoom -->
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Zoom: In" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="9" Grid.Column="1" x:Name="ZoomInP1TextBox" TabIndex="62" Margin="0,4,8,0" ToolTip="Example: MouseWheelUp or Num8"/>
                    <TextBox Grid.Row="9" Grid.Column="2" x:Name="ZoomInP2TextBox" TabIndex="63" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Zoom: Out" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="10" Grid.Column="1" x:Name="ZoomOutP1TextBox" TabIndex="64" Margin="0,4,8,0" ToolTip="Example: MouseWheelDown or Num2"/>
                    <TextBox Grid.Row="10" Grid.Column="2" x:Name="ZoomOutP2TextBox" TabIndex="65" Margin="0,4,0,0"/>

                    <!-- Others -->
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="Others: Fire weapon" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="11" Grid.Column="1" x:Name="FireWeaponP1TextBox" TabIndex="66" Margin="0,4,8,0" ToolTip="Example: MouseLeft or Key Q. This action maps to two internal entries (0x12/0x13); both are updated."/>
                    <TextBox Grid.Row="11" Grid.Column="2" x:Name="FireWeaponP2TextBox" TabIndex="67" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Others: Select weapon" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="12" Grid.Column="1" x:Name="SelectWeaponP1TextBox" TabIndex="68" Margin="0,4,8,0" ToolTip="Example: MouseRight or Key W"/>
                    <TextBox Grid.Row="12" Grid.Column="2" x:Name="SelectWeaponP2TextBox" TabIndex="69" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Others: Transform" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="13" Grid.Column="1" x:Name="TransformP1TextBox" TabIndex="70" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="13" Grid.Column="2" x:Name="TransformP2TextBox" TabIndex="71" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="14" Grid.Column="0" Text="Others: Air brake" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="14" Grid.Column="1" x:Name="AirBrakeP1TextBox" TabIndex="72" Margin="0,4,8,0"/>
                    <TextBox Grid.Row="14" Grid.Column="2" x:Name="AirBrakeP2TextBox" TabIndex="73" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="15" Grid.Column="0" Text="Others: Special function" Margin="0,4,8,0"/>
	                    <TextBox Grid.Row="15" Grid.Column="1" x:Name="SpecialFunctionP1TextBox" TabIndex="74" Margin="0,4,8,0"/>
	                    <TextBox Grid.Row="15" Grid.Column="2" x:Name="SpecialFunctionP2TextBox" TabIndex="75" Margin="0,4,0,0"/>
	                </Grid>
                    </Border>
	                </StackPanel>
	                </Expander>

	                <TextBlock x:Name="GodModeNoteTextBlock" Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextWrapping="Wrap">
	                    <Run FontWeight="SemiBold">God Mode:</Run> Cheat-gated at runtime (save-name substring checks). The save persists a toggle state (<Run FontFamily="Consolas">g_bGodModeEnabled</Run>), but the Steam build’s per-player persistence is not mapped reliably; save patching is not a reliable way to enable god mode.
	                </TextBlock>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        </StackPanel>
        </ScrollViewer>

        <!-- Action Bar (outside scroll area so it's always visible) -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceMutedBrush}"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="SaveEditorHintText"
                               Text="Use Save Analyzer tab to analyze or compare files"
                               Style="{StaticResource HelperTextStyle}"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Name="PendingChangesText"
                               Text="No pending changes selected yet."
                               Style="{StaticResource HelperTextStyle}"/>
                </StackPanel>
                <Button x:Name="PatchButton"
                        Grid.Column="1"
                        Content="PATCH SAVE"
                        Style="{StaticResource PrimaryButtonStyle}"
                        TabIndex="76"
                        AutomationProperties.Name="Patch file button"
                        Click="PatchButton_Click"
                        Padding="24,10"
                        MinWidth="140"
                        MinHeight="40"
                        VerticalAlignment="Center"
                        IsEnabled="False"
                        ToolTip="Apply patches to the selected file"/>
            </Grid>
        </Border>

        <!-- Output -->
        <GroupBox Grid.Row="2" Header="Patch Output" Style="{StaticResource OutputGroupBoxStyle}">
            <Grid Margin="10,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                    <TextBlock Style="{StaticResource HelperTextStyle}" DockPanel.Dock="Left">
                        Save patch output for the current file and selection.
                    </TextBlock>
                    <Button x:Name="CopyOutputButton"
                            Content="Copy"
                            TabIndex="77"
                            AutomationProperties.Name="Copy output button"
                            Click="CopyOutputButton_Click"
                            Padding="10,3"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            ToolTip="Copy output to clipboard"/>
                </DockPanel>

                <TextBox x:Name="StatusTextBox"
                         Grid.Row="1"
                         Style="{StaticResource OutputTextBoxStyle}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
