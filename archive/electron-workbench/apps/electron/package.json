{
  "name": "@onslaught/electron",
  "private": true,
  "version": "0.0.0",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./job-runner": {
      "types": "./dist/job-runner.d.ts",
      "require": "./dist/job-runner.js",
      "default": "./dist/job-runner.js"
    },
    "./re-workbench": {
      "types": "./dist/re-workbench.d.ts",
      "require": "./dist/re-workbench.js",
      "default": "./dist/re-workbench.js"
    }
  },
  "typesVersions": {
    "*": {
      "job-runner": ["dist/job-runner.d.ts"],
      "re-workbench": ["dist/re-workbench.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:parity": "node scripts/save-inspector-parity.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@onslaught/contracts": "0.0.0"
  }
}
