# Retail-derived rebuild outputs are materialized locally from a user-owned
# installation and remain untracked. Source paths already match the payload
# extension rules above; these two bounded OBJ roots need explicit coverage.
/rebuild/OnslaughtRebuild.Godot/Assets/Aquila/*.obj
/rebuild/OnslaughtRebuild.Godot/Assets/Level100/*.obj

# Canonical reviewed RE database exception.
!reverse-engineering/ghidra/
!reverse-engineering/ghidra/**

# Narrow public-primary regression fixture exception.
!tests_shared/fixtures/gold_career_save.bin
